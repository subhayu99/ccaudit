{
  "name": "@subhayu99/ccaudit",
  "version": "0.5.0",
  "description": "Browse, search, and audit your Claude Code session history",
  "type": "module",
  "author": "subhayu99",
  "license": "MIT",
  "homepage": "https://github.com/subhayu99/ccaudit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subhayu99/ccaudit.git"
  },
  "bugs": {
    "url": "https://github.com/subhayu99/ccaudit/issues"
  },
  "keywords": [
    "ccaudit",
    "claude",
    "claude-code",
    "cli",
    "session-history",
    "search",
    "audit",
    "sqlite",
    "developer-tools"
  ],
  "bin": {
    "ccaudit": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "dist-web/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && astro build",
    "build:cli": "tsup",
    "build:web": "astro build",
    "dev": "tsx src/cli/index.ts",
    "astro:dev": "astro dev --port 4321",
    "astro:preview": "astro preview --port 4321",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "astro check && tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "astro": "^5.18.1",
    "commander": "^12.1.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "kleur": "^4.1.5",
    "marked": "^14.1.4",
    "shiki": "^1.29.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^22.7.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
