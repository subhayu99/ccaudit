{
  "name": "ccaudit",
  "version": "0.0.1",
  "description": "Browse, search, and audit your Claude Code session history",
  "type": "module",
  "bin": {
    "ccaudit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
