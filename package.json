{
  "name": "ccaudit",
  "version": "0.0.1",
  "description": "Browse, search, and audit your Claude Code session history",
  "type": "module",
  "bin": {
    "ccaudit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:web": "astro build",
    "dev": "tsx src/cli/index.ts",
    "astro:dev": "astro dev --port 4321",
    "astro:preview": "astro preview --port 4321",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "astro check && tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "astro": "^5.18.1",
    "better-sqlite3": "^11.5.0",
    "commander": "^12.1.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "kleur": "^4.1.5",
    "marked": "^14.1.4",
    "shiki": "^1.29.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^22.7.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
