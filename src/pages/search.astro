---
import AppShell from "../layouts/AppShell.astro";
import Sidebar from "../components/Sidebar.astro";
import { getDb } from "../db/init";
import { searchMessages, searchMessagesExact, searchMessagesRegex, searchSessionIdsByTitle } from "../db/messages";
import { getSessionsByIds } from "../db/sessions";
import { getLibraryTree } from "../db/library";
import { listTopics } from "../db/topics";
import { resolveRange } from "../db/date-range";
import { formatTimestamp } from "../lib/render";
import type { Session } from "../types";

const query = Astro.url.searchParams.get("q")?.trim() ?? "";
const mode = (Astro.url.searchParams.get("mode") ?? "fts") as "fts" | "exact" | "regex";

type Line = { lineNo: number; snippet: string };
type SGroup = { sessionId: string; title: string; sub: string; lastActivity: number | null; lines: Line[] };
let groups: SGroup[] = [];
let totalHits = 0;
let searchError = "";

const range = resolveRange(Astro.cookies.get("ccaudit-range")?.value, Date.now());
const db = getDb();
const tree = getLibraryTree(db, range);
const topics = listTopics(db, range);
if (query) {
  try {
    const raw =
      mode === "exact" ? searchMessagesExact(db, query, { limit: 200, range })
      : mode === "regex" ? searchMessagesRegex(db, query, { limit: 200, range })
      : searchMessages(db, query, { limit: 200, range });
    totalHits = raw.length;
    const sessions = getSessionsByIds(db, raw.map((h) => h.sessionId));
    // Group by session, preserving best-rank session order; lines sorted chronologically.
    const order: string[] = [];
    const map = new Map<string, SGroup>();
    for (const h of raw) {
      let g = map.get(h.sessionId);
      if (!g) {
        const s: Session | undefined = sessions.get(h.sessionId);
        g = {
          sessionId: h.sessionId,
          title: (s?.aiTitle || s?.firstPrompt || h.sessionId.slice(0, 8)).replace(/\s+/g, " ").trim(),
          sub: s?.projectLabel ?? "unknown",
          lastActivity: s?.lastActivity ?? null,
          lines: [],
        };
        map.set(h.sessionId, g);
        order.push(h.sessionId);
      }
      g.lines.push({ lineNo: h.lineNo, snippet: h.snippet });
    }
    groups = order.map((id) => {
      const g = map.get(id)!;
      g.lines.sort((a, b) => a.lineNo - b.lineNo);
      return g;
    });
    // Also surface sessions matching by TITLE or ID (even with no message-content hit).
    const titleIds = searchSessionIdsByTitle(db, query, { range }).filter((id) => !map.has(id));
    if (titleIds.length) {
      const ts = getSessionsByIds(db, titleIds);
      for (const id of titleIds) {
        const s: Session | undefined = ts.get(id);
        groups.push({
          sessionId: id,
          title: (s?.aiTitle || s?.firstPrompt || id.slice(0, 8)).replace(/\s+/g, " ").trim(),
          sub: s?.projectLabel ?? "unknown",
          lastActivity: s?.lastActivity ?? null,
          lines: [],
        });
      }
    }
  } catch (e) {
    searchError = e instanceof Error ? e.message : String(e);
  }
}

const modes = [
  { key: "fts", label: "Smart", desc: "Full-text with stemming & ranking" },
  { key: "exact", label: "Exact", desc: "Case-insensitive substring match" },
  { key: "regex", label: "Regex", desc: "Case-insensitive regular expression" },
] as const;
---
<AppShell title={query ? `ccaudit — search: ${query}` : "ccaudit — search"}>
  <Sidebar slot="sidebar" tree={tree} topics={topics} />
  <div slot="reader" class="p-8 max-w-[900px]">
    <h1 class="font-serif text-2xl font-semibold mb-4" style="color:var(--text);">Search</h1>

    <form action="/search" method="get" class="mb-4">
      <div class="flex gap-2 max-w-xl">
        <input type="search" name="q" value={query} placeholder="Search all sessions…" autofocus
          class="flex-1 px-4 py-2 text-base rounded-lg focus:outline-none"
          style="background:var(--panel); border:1px solid var(--border); color:var(--text);" />
        <input type="hidden" name="mode" value={mode} />
        <button type="submit" class="px-4 py-2 text-sm font-semibold rounded-lg" style="background:var(--amber); color:#241f17;">Search</button>
      </div>
    </form>

    <div class="flex gap-1.5 mb-6 items-center flex-wrap">
      {modes.map((m) => {
        const href = query ? `/search?q=${encodeURIComponent(query)}&mode=${m.key}` : `/search?mode=${m.key}`;
        return <a href={href} class="smode" data-on={mode === m.key} title={m.desc}>{m.label}</a>;
      })}
      <span class="text-xs ml-2" style="color:var(--text-faint);">{modes.find((m) => m.key === mode)?.desc}</span>
    </div>

    {searchError && (
      <div class="rounded-lg p-4 mb-4 text-sm" style="background:rgba(180,60,60,.12); border:1px solid rgba(180,60,60,.4); color:#e0a0a0;">
        <strong>Search error:</strong> {searchError}
      </div>
    )}
    {query && !searchError && groups.length === 0 && (
      <p style="color:var(--text-dim);">No matches for <strong>"{query}"</strong> in {mode} mode.</p>
    )}
    {!query && <p style="color:var(--text-dim);">Type a query to search across all indexed messages.</p>}

    {groups.length > 0 && (
      <>
        <div class="flex items-center gap-3 mb-3 flex-wrap">
          <p class="text-sm" style="color:var(--text-faint);">
            {totalHits} match{totalHits === 1 ? "" : "es"} in {groups.length} session{groups.length === 1 ? "" : "s"} for <strong style="color:var(--text-dim);">"{query}"</strong>
          </p>
          <button id="toggle-all" class="toggle-all" type="button" data-state="open">Collapse all</button>
          <button id="hide-matching" class="toggle-all hide-matching" type="button" data-q={query} title="Hide every session whose title or your messages match this query">✕ Hide all matching</button>
        </div>
        <div id="results">
          {groups.map((g) => (
            <details open class="sgroup">
              <summary class="sgroup-head">
                <span class="chev">▸</span>
                <span class="g-title">{g.title}</span>
                <span class="g-sub">{g.sub}{g.lastActivity ? ` · ${formatTimestamp(g.lastActivity)}` : ""}</span>
                <span class="g-count">{g.lines.length}</span>
                <button class="shide" type="button" data-session={g.sessionId} title="Hide this session from all views">✕</button>
              </summary>
              <div class="sgroup-body">
                {g.lines.map((line) => (
                  <a href={`/?session=${g.sessionId}#m${line.lineNo}`} class="sline">
                    <span class="ln">line {line.lineNo}</span>
                    <span class="snip" set:html={line.snippet}></span>
                  </a>
                ))}
              </div>
            </details>
          ))}
        </div>
      </>
    )}
  </div>

  <script is:inline>
    // Expand/collapse-all toggle over the per-session <details> groups.
    const tbtn = document.getElementById("toggle-all");
    if (tbtn) {
      tbtn.addEventListener("click", () => {
        const collapse = tbtn.dataset.state === "open";
        document.querySelectorAll("#results details.sgroup").forEach((d) => (d.open = !collapse));
        tbtn.dataset.state = collapse ? "closed" : "open";
        tbtn.textContent = collapse ? "Expand all" : "Collapse all";
      });
    }

    // Hiding: a session (id rule) or everything matching the query (phrase rule). Manage in Hidden.
    async function hide(payload) {
      await fetch("/api/exclusions", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
    }
    document.querySelectorAll(".shide").forEach((b) =>
      b.addEventListener("click", async (e) => {
        e.preventDefault(); e.stopPropagation();
        await hide({ action: "add-rule", kind: "session", value: b.dataset.session });
        b.closest("details")?.remove();
      }));
    const hm = document.getElementById("hide-matching");
    hm?.addEventListener("click", async () => {
      const q = hm.dataset.q;
      if (!q) return;
      if (!confirm(`Hide every session whose title or your messages contain “${q}”?\nThis saves a reusable rule — undo it anytime in Hidden.`)) return;
      await hide({ action: "add-rule", kind: "phrase", value: q });
      location.href = "/search?q=" + encodeURIComponent(q);
    });
  </script>

  <style>
    .smode { padding:6px 12px; font-size:13px; border-radius:8px; background:var(--raise); color:var(--text-dim); text-decoration:none; }
    .smode[data-on="true"] { background:var(--amber); color:#241f17; font-weight:600; }
    .toggle-all { font-size:12px; padding:4px 11px; border-radius:8px; background:var(--raise); color:var(--text-dim); border:1px solid var(--border); cursor:pointer; }
    .toggle-all:hover { color:var(--text); }
    .hide-matching:hover { color:#e0a0a0; border-color:rgba(180,60,60,.5); }
    .shide { margin-left:8px; flex:none; background:none; border:none; color:var(--text-faint); cursor:pointer; font-size:12px; opacity:0; transition:opacity .12s, color .12s; padding:0 2px; }
    .sgroup-head:hover .shide { opacity:1; }
    .shide:hover { color:#e0a0a0; }
    /* Per-session collapsible group (native <details>, open by default). */
    .sgroup { background:var(--panel); border:1px solid var(--border-soft); border-radius:12px; margin-bottom:10px; overflow:hidden; }
    .sgroup-head { display:flex; align-items:center; gap:10px; padding:11px 14px; cursor:pointer; list-style:none; user-select:none; }
    .sgroup-head::-webkit-details-marker { display:none; }
    .sgroup-head:hover { background:var(--panel-2); }
    .sgroup .chev { color:var(--text-faint); font-size:11px; flex:none; transition:transform .15s ease; }
    .sgroup[open] .chev { transform:rotate(90deg); }
    .g-title { color:var(--text); font-weight:600; font-size:14px; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .g-sub { color:var(--text-faint); font-family:var(--mono); font-size:11.5px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:38%; }
    .g-count { color:var(--amber); font-family:var(--mono); font-size:11.5px; background:rgba(210,168,95,.14); border-radius:10px; padding:1px 9px; flex:none; }
    .sgroup-body { border-top:1px solid var(--border-soft); padding:4px; }
    .sline { display:flex; gap:12px; align-items:baseline; padding:7px 10px; border-radius:8px; text-decoration:none; }
    .sline:hover { background:var(--raise); }
    .sline .ln { color:var(--amber); font-family:var(--mono); font-size:11px; flex:none; min-width:62px; }
    .sline .snip { color:var(--text-dim); font-size:13px; line-height:1.5; flex:1; }
    .sline .snip :global(mark) { background:rgba(210,168,95,.32); color:var(--amber-bright); border-radius:3px; padding:0 2px; }
  </style>
</AppShell>
