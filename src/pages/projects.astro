---
import AppShell from "../layouts/AppShell.astro";
import Sidebar from "../components/Sidebar.astro";
import { getDb } from "../db/init";
import { listProjects } from "../db/sessions";
import { listExclusions } from "../db/exclusions";
import { getLibraryTree } from "../db/library";
import { listTopics } from "../db/topics";
import { resolveRange } from "../db/date-range";
import { formatTimestamp } from "../lib/render";

const range = resolveRange(Astro.cookies.get("ccaudit-range")?.value, Date.now());
const db = getDb();
const projects = listProjects(db);
const hidden = listExclusions(db);
const tree = getLibraryTree(db, range);
const topics = listTopics(db);
---
<AppShell title="ccaudit — directories">
  <Sidebar slot="sidebar" tree={tree} topics={topics} />
  <div slot="reader" class="p-8 max-w-[1000px]">
    <h1 class="font-serif text-2xl font-semibold mb-1" style="color:var(--text);">Directories</h1>
    <p class="text-[13px] mb-5" style="color:var(--text-dim);">Hide noisy directories from every view. Hiding is lossless — data is kept, just filtered.</p>

    {hidden.length > 0 && (
      <div class="rounded-xl mb-6" style="background:var(--panel); border:1px solid var(--border-soft);">
        <div class="px-4 py-2.5 text-[11px] uppercase tracking-wider" style="color:var(--text-faint); border-bottom:1px solid var(--border-soft);">{hidden.length} hidden</div>
        {hidden.map((prefix) => (
          <div class="flex items-center justify-between gap-3 px-4 py-2.5" style="border-bottom:1px solid var(--border-soft);">
            <code class="text-xs font-mono-w break-all" style="color:var(--text-dim);">{prefix}</code>
            <button data-exclude-action="remove" data-exclude-prefix={prefix} class="pbtn shrink-0">Unhide</button>
          </div>
        ))}
      </div>
    )}

    <div class="rounded-xl overflow-hidden" style="background:var(--panel); border:1px solid var(--border-soft);">
      <table class="w-full text-sm">
        <thead>
          <tr style="color:var(--text-faint); border-bottom:1px solid var(--border-soft);">
            <th class="px-3 py-2 text-left font-medium text-[11px] uppercase tracking-wider">Last activity</th>
            <th class="px-3 py-2 text-left font-medium text-[11px] uppercase tracking-wider">Project</th>
            <th class="px-3 py-2 text-right font-medium text-[11px] uppercase tracking-wider">Sessions</th>
            <th class="px-3 py-2 text-left font-medium text-[11px] uppercase tracking-wider">Path</th>
            <th class="px-3 py-2"></th>
          </tr>
        </thead>
        <tbody>
          {projects.map((p) => (
            <tr class="prow" style="border-bottom:1px solid var(--border-soft);">
              <td class="px-3 py-2 whitespace-nowrap" style="color:var(--text-dim);">{formatTimestamp(p.lastActivity)}</td>
              <td class="px-3 py-2 font-semibold"><span style="color:var(--amber);">{p.projectLabel}</span></td>
              <td class="px-3 py-2 text-right tabular-nums" style="color:var(--text-dim);">{p.sessionCount}</td>
              <td class="px-3 py-2 font-mono-w text-xs" style="color:var(--text-faint);">{p.projectDir}</td>
              <td class="px-3 py-2 text-right" onclick="event.stopPropagation()">
                <button data-exclude-action="add" data-exclude-prefix={p.projectDir} title={`Hide ${p.projectDir}`} class="pbtn">Hide</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <style>
    .prow:hover { background:var(--panel-2); }
    .pbtn { padding:4px 10px; font-size:12px; font-weight:500; border-radius:7px; background:var(--raise); color:var(--text-dim); border:1px solid var(--border); cursor:pointer; }
    .pbtn:hover { background:var(--border); color:var(--text); }
    .pbtn[disabled] { cursor:default; opacity:.6; }
    .pbtn-busy { position:relative; color:transparent !important; }
    .pbtn-busy::after { content:""; position:absolute; inset:0; margin:auto; width:11px; height:11px; border-radius:50%; border:1.5px solid var(--text-faint); border-top-color:var(--amber-bright); animation:pbtn-spin .6s linear infinite; }
    @keyframes pbtn-spin { to { transform:rotate(360deg); } }
  </style>

  <script>
    // Shared thin top progress bar (element lives in <Sidebar>); show it the instant
    // a hide/unhide action fires, before the reload.
    const progressEl = document.getElementById("topbar-progress");
    let excludeInFlight = false;
    document.querySelectorAll("[data-exclude-action]").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        if (excludeInFlight) return; // guard against double-clicks across all controls
        const el = e.currentTarget as HTMLButtonElement;
        excludeInFlight = true;
        el.disabled = true;
        el.classList.add("pbtn-busy");
        progressEl?.classList.add("active");
        try {
          const res = await fetch("/api/exclusions", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ action: el.dataset.excludeAction, prefix: el.dataset.excludePrefix }),
          });
          if (res.ok) { location.reload(); }
          else { excludeInFlight = false; el.disabled = false; el.classList.remove("pbtn-busy"); progressEl?.classList.remove("active"); }
        } catch { excludeInFlight = false; el.disabled = false; el.classList.remove("pbtn-busy"); progressEl?.classList.remove("active"); }
      });
    });
  </script>
</AppShell>
