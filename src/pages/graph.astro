---
import AppShell from "../layouts/AppShell.astro";
import Sidebar from "../components/Sidebar.astro";
import { getDb } from "../db/init";
import { getGraphData } from "../db/graph";
import { getRepoGraphData } from "../db/repo-graph";
import { getTopicGraphData } from "../db/topic-graph";
import { getLibraryTree } from "../db/library";

const vparam = Astro.url.searchParams.get("view");
const view = vparam === "repos" ? "repos" : vparam === "topics" ? "topics" : "folders";

const db = getDb();
const graph = view === "topics" ? getTopicGraphData(db) : view === "repos" ? getRepoGraphData(db) : getGraphData(db);
const tree = getLibraryTree(db);

const count = (t: string) => graph.nodes.filter((n) => n.type === t).length;

// Passed to the client via a hidden element's data-* attribute (Astro escapes it).
// Avoids a <script type="application/json"> tag, which Vite's dev dependency
// scanner mis-parses (it inlines the frontmatter and chokes).
const graphJson = JSON.stringify(graph);
---
<AppShell title="ccaudit — graph">
  <Sidebar slot="sidebar" tree={tree} />
  <div slot="reader" class="flex flex-col h-screen p-5">
  <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
    <h1 class="font-serif text-2xl font-semibold" style="color:var(--text);">Graph</h1>
    <div class="flex items-center gap-4 text-sm" style="color:var(--text-dim);">
      {view === "topics" ? (
        <>
          <span class="flex items-center gap-1.5">
            <span class="inline-block w-3 h-3 rounded-full bg-amber-500"></span> {count("topic")} topics
          </span>
          <span class="flex items-center gap-1.5">
            <span class="inline-block w-3 h-3 rounded-full bg-blue-500"></span> {count("session")} sessions
          </span>
        </>
      ) : view === "repos" ? (
        <>
          <span class="flex items-center gap-1.5">
            <span class="inline-block w-3 h-3 rounded-full bg-emerald-500"></span> {count("repo")} repos
          </span>
          <span class="flex items-center gap-1.5">
            <span class="inline-block w-3 h-3 rounded-full bg-violet-500"></span> {count("workdir")} workdirs
          </span>
          <span class="flex items-center gap-1.5">
            <span class="inline-block w-3 h-3 rounded-full bg-blue-500"></span> {count("session")} sessions
          </span>
          <span class="flex items-center gap-1.5">
            <span class="inline-block w-3 h-3 rounded-full border border-slate-400 opacity-40"></span> deleted dir
          </span>
        </>
      ) : (
        <>
          <span class="flex items-center gap-1.5">
            <span class="inline-block w-3 h-3 rounded-full bg-slate-400"></span> {count("folder")} folders
          </span>
          <span class="flex items-center gap-1.5">
            <span class="inline-block w-3 h-3 rounded-full bg-violet-500"></span> {count("project")} projects
          </span>
          <span class="flex items-center gap-1.5">
            <span class="inline-block w-3 h-3 rounded-full bg-blue-500"></span> {count("session")} sessions
          </span>
          <span class="flex items-center gap-1.5">
            <span class="inline-block w-3 h-3 rounded-full bg-amber-500"></span> compacted
          </span>
        </>
      )}
    </div>
  </div>

  <div class="flex items-center gap-3 mb-3 flex-wrap">
    <div class="inline-flex rounded-lg overflow-hidden text-sm" style="border:1px solid var(--border);">
      <a href="/graph" class="gtab" data-on={view === "folders"}>Folders</a>
      <a href="/graph?view=repos" class="gtab" data-on={view === "repos"} style="border-left:1px solid var(--border);">Repos</a>
      <a href="/graph?view=topics" class="gtab" data-on={view === "topics"} style="border-left:1px solid var(--border);">Topics</a>
    </div>
    <input
      id="graph-search"
      type="search"
      placeholder="Highlight nodes…"
      class="px-3 py-1.5 text-sm rounded-lg w-64 focus:outline-none"
      style="background:var(--panel); border:1px solid var(--border); color:var(--text);"
    />
    {view === "folders" && (
      <label class="flex items-center gap-2 text-sm cursor-pointer select-none" style="color:var(--text-dim);">
        <input id="graph-continuations" type="checkbox" class="rounded" />
        Show session threads
      </label>
    )}
    <span class="text-sm ml-auto hidden sm:inline" style="color:var(--text-faint);">drag · scroll to zoom · click to open</span>
  </div>

  <div
    id="graph-container"
    class="relative rounded-lg overflow-hidden flex-1"
    style="background:var(--panel); border:1px solid var(--border-soft);"
  >
    <svg id="graph-svg" width="100%" height="100%" style="display:block;"></svg>
    <div
      id="graph-tooltip"
      class="pointer-events-none absolute hidden px-2 py-1 text-xs rounded-md shadow-lg max-w-xs z-10"
      style="background:#0f0d0b; color:var(--text); border:1px solid var(--border);"
    ></div>
    <button
      id="graph-reset"
      class="absolute bottom-3 right-3 px-3 py-1.5 text-xs font-medium rounded-lg"
      style="background:var(--raise); color:var(--text-dim); border:1px solid var(--border);"
    >
      Reset view
    </button>
  </div>

  <div id="graph-data" data-graph={graphJson} hidden></div>

  <script>
    // @ts-nocheck — client-side d3 viz glue; types relaxed for brevity.
    import { forceSimulation, forceManyBody, forceLink, forceCenter, forceCollide, forceX, forceY } from "d3-force";
    import { select } from "d3-selection";
    import { zoom, zoomIdentity } from "d3-zoom";
    import { drag } from "d3-drag";

    const data = JSON.parse(document.getElementById("graph-data").dataset.graph);
    const container = document.getElementById("graph-container");
    const svgEl = document.getElementById("graph-svg");
    const tooltip = document.getElementById("graph-tooltip");

    let width = container.clientWidth;
    let height = container.clientHeight;

    const isDark = !document.documentElement.classList.contains("theme-light");
    const C = isDark
      ? { folder: "#6f685b", proj: "#9b82d6", sess: "#6fa1d8", sessCompact: "#cf8a4a", edge: "#37312a", cont: "#7fae7a", label: "#a39a87", folderLabel: "#6f685b", stroke: "#1b1916", repo: "#7fae7a", workdir: "#9b82d6", workdirGone: "#6f685b", topic: "#d2a85f" }
      : { folder: "#9a917d", proj: "#7c5cc4", sess: "#3b6fa8", sessCompact: "#b9722f", edge: "#d8cfba", cont: "#5a8a55", label: "#6b6452", folderLabel: "#9a917d", stroke: "#f5f1e8", repo: "#5a8a55", workdir: "#7c5cc4", workdirGone: "#c9c0ad", topic: "#b9722f" };

    // Split links: structural ones drive the layout; continuation ones are overlay-only.
    const structuralLinks = data.links.filter((l) => l.kind !== "continuation");
    const continuationLinks = data.links.filter((l) => l.kind === "continuation");

    const folderRadius = (d) => Math.max(8, Math.sqrt(d.projectCount || 1) * 6);
    const projRadius = (d) => Math.max(6, Math.sqrt(d.sessionCount || 1) * 4);
    const sessRadius = (d) => Math.max(3, Math.sqrt(d.messageCount || 1) * 0.55);
    const repoRadius = (d) => Math.max(9, Math.sqrt(d.workdirCount || 1) * 6);
    const nodeRadius = (d) =>
      d.type === "folder" ? folderRadius(d)
      : d.type === "topic" ? Math.max(9, Math.sqrt(d.sessionCount || 1) * 5)
      : d.type === "repo" ? repoRadius(d)
      : d.type === "project" ? projRadius(d)
      : d.type === "workdir" ? 7
      : sessRadius(d);
    const nodeFill = (d) =>
      d.type === "folder" ? C.folder
      : d.type === "topic" ? C.topic
      : d.type === "repo" ? C.repo
      : d.type === "project" ? C.proj
      : d.type === "workdir" ? (d.existsOnDisk ? C.workdir : C.workdirGone)
      : d.compactCount > 0 ? C.sessCompact : C.sess;
    // Always-visible labels for everything except sessions (which show on hover).
    const showsLabel = (d) => d.type !== "session";

    const svg = select(svgEl);
    const root = svg.append("g");

    const zoomBehavior = zoom()
      .scaleExtent([0.05, 8])
      .on("zoom", (event) => root.attr("transform", event.transform));
    svg.call(zoomBehavior);

    // Continuation edges (overlay, hidden by default) — rendered first so they sit behind.
    // Keep a reference to the GROUP so the toggle flips its display, not each line's.
    const contGroup = root
      .append("g")
      .attr("stroke", C.cont)
      .attr("stroke-opacity", 0.55)
      .attr("stroke-dasharray", "4 3")
      .style("display", "none");
    const contLink = contGroup
      .selectAll("line")
      .data(continuationLinks)
      .join("line")
      .attr("stroke-width", 1.2);

    // Structural edges
    const link = root
      .append("g")
      .attr("stroke", C.edge)
      .attr("stroke-opacity", 0.45)
      .selectAll("line")
      .data(structuralLinks)
      .join("line")
      .attr("stroke-width", (d) => (d.kind === "project-folder" ? 1.4 : 1));

    // Nodes
    const node = root
      .append("g")
      .selectAll("g")
      .data(data.nodes)
      .join("g")
      .style("cursor", "pointer");

    node
      .append("circle")
      .attr("r", nodeRadius)
      .attr("fill", nodeFill)
      .attr("fill-opacity", (d) => (d.type === "folder" ? 0.55 : d.type === "workdir" && !d.existsOnDisk ? 0.5 : 1))
      .attr("stroke", (d) => (d.type === "workdir" && !d.existsOnDisk ? C.workdir : C.stroke))
      .attr("stroke-width", 1.5)
      .attr("stroke-dasharray", (d) => (d.type === "workdir" && !d.existsOnDisk ? "2 2" : null));

    // Hubs (folder/repo/project/workdir) labelled always; sessions only on hover.
    const label = node
      .append("text")
      .text((d) => (showsLabel(d) ? d.label : ""))
      .attr("font-size", (d) => (d.type === "folder" || d.type === "repo" ? 12 : d.type === "project" ? 11 : 9))
      .attr("font-weight", (d) => (d.type === "session" ? 400 : 600))
      .attr("fill", (d) => (d.type === "folder" ? C.folderLabel : C.label))
      .attr("dx", (d) => nodeRadius(d) + 4)
      .attr("dy", 3)
      .style("pointer-events", "none")
      .style("paint-order", "stroke")
      .attr("stroke", C.stroke)
      .attr("stroke-width", 3)
      .attr("stroke-opacity", 0.7);

    // Neighbor lookup for hover highlighting (structural links only)
    const linkedByIndex = new Set();
    structuralLinks.forEach((l) => linkedByIndex.add(l.source + "|" + l.target));
    function connected(a, b) {
      return a.id === b.id || linkedByIndex.has(a.id + "|" + b.id) || linkedByIndex.has(b.id + "|" + a.id);
    }

    function truncate(s, n) {
      return s && s.length > n ? s.slice(0, n - 1) + "…" : s || "";
    }

    node
      .on("mouseover", function (event, d) {
        node.style("opacity", (o) => (connected(d, o) ? 1 : 0.12));
        link.style("stroke-opacity", (l) => (l.source.id === d.id || l.target.id === d.id ? 0.85 : 0.04));
        if (d.type === "session") {
          select(this).select("text").text(truncate(d.label, 40)).attr("font-weight", 600);
        } else {
          select(this).select("text").attr("font-weight", 700);
        }
        let meta;
        if (d.type === "folder") meta = `${d.projectCount} projects`;
        else if (d.type === "project") meta = `${d.sessionCount} session${d.sessionCount === 1 ? "" : "s"}`;
        else if (d.type === "repo")
          meta = `${d.workdirCount} workdir${d.workdirCount === 1 ? "" : "s"}${d.remote ? ` · ${d.remote}` : ""}`;
        else if (d.type === "workdir")
          meta = `${d.existsOnDisk ? "" : "⚠ deleted · "}${d.workdirPath}`;
        else meta = `${d.messageCount} msgs${d.compactCount > 0 ? ` · ${d.compactCount} compact` : ""}`;
        tooltip.innerHTML = `<div class="font-semibold">${truncate(d.label, 80)}</div><div class="text-slate-400 break-all">${truncate(meta, 120)}</div>`;
        tooltip.classList.remove("hidden");
      })
      .on("mousemove", function (event) {
        const rect = container.getBoundingClientRect();
        tooltip.style.left = event.clientX - rect.left + 12 + "px";
        tooltip.style.top = event.clientY - rect.top + 12 + "px";
      })
      .on("mouseout", function (event, d) {
        node.style("opacity", 1);
        link.style("stroke-opacity", 0.45);
        select(this)
          .select("text")
          .text(d.type === "session" ? "" : d.label)
          .attr("font-weight", d.type === "session" ? 400 : 600);
        tooltip.classList.add("hidden");
      })
      .on("click", (event, d) => {
        if (event.defaultPrevented) return;
        if (d.type === "session") window.location.href = "/s/" + d.sessionId;
        else if (d.type === "project") window.location.href = "/?project=" + encodeURIComponent(d.projectDir);
        else if (d.type === "topic") window.location.href = "/?topic=" + d.id.slice(6);
        // folder/repo/workdir click: no-op (visual grouping)
      });

    // Force simulation — only structural links drive layout.
    const charge = (d) =>
      d.type === "folder" || d.type === "repo" ? -400
      : d.type === "project" || d.type === "workdir" ? -160
      : -36;
    const linkDistance = (l) =>
      l.kind === "project-folder" ? 70 : l.kind === "workdir-repo" ? 60 : 32;
    const sim = forceSimulation(data.nodes)
      .force("link", forceLink(structuralLinks).id((d) => d.id).distance(linkDistance).strength(0.5))
      .force("charge", forceManyBody().strength(charge))
      .force("center", forceCenter(width / 2, height / 2))
      .force("x", forceX(width / 2).strength(0.03))
      .force("y", forceY(height / 2).strength(0.03))
      .force("collide", forceCollide().radius((d) => nodeRadius(d) + 3))
      .on("tick", ticked);

    function ticked() {
      link
        .attr("x1", (d) => d.source.x)
        .attr("y1", (d) => d.source.y)
        .attr("x2", (d) => d.target.x)
        .attr("y2", (d) => d.target.y);
      contLink
        .attr("x1", (d) => d.source.x)
        .attr("y1", (d) => d.source.y)
        .attr("x2", (d) => d.target.x)
        .attr("y2", (d) => d.target.y);
      node.attr("transform", (d) => `translate(${d.x},${d.y})`);
    }

    // Resolve continuation link endpoints to node objects (forceLink does this for
    // structural links, but continuation links aren't in the simulation).
    const nodeById = new Map(data.nodes.map((n) => [n.id, n]));
    continuationLinks.forEach((l) => {
      if (typeof l.source === "string") l.source = nodeById.get(l.source);
      if (typeof l.target === "string") l.target = nodeById.get(l.target);
    });

    // Drag
    node.call(
      drag()
        .on("start", (event, d) => {
          if (!event.active) sim.alphaTarget(0.3).restart();
          d.fx = d.x;
          d.fy = d.y;
        })
        .on("drag", (event, d) => {
          d.fx = event.x;
          d.fy = event.y;
        })
        .on("end", (event, d) => {
          if (!event.active) sim.alphaTarget(0);
          d.fx = null;
          d.fy = null;
        })
    );

    // Continuation toggle — flips the whole overlay group's visibility.
    // Only present in the Folders view (the Repos view has no continuation links).
    const contToggle = document.getElementById("graph-continuations");
    if (contToggle) {
      contToggle.addEventListener("change", (e) => {
        contGroup.style("display", e.target.checked ? null : "none");
      });
    }

    // In-graph search: highlight matching node labels, dim the rest.
    const searchInput = document.getElementById("graph-search");
    searchInput.addEventListener("input", () => {
      const q = searchInput.value.trim().toLowerCase();
      if (!q) {
        node.style("opacity", 1);
        link.style("stroke-opacity", 0.45);
        label.text((d) => (d.type === "session" ? "" : d.label));
        return;
      }
      node.style("opacity", (d) => (d.label.toLowerCase().includes(q) ? 1 : 0.1));
      link.style("stroke-opacity", 0.05);
      // Reveal labels of matching session nodes too
      label.text((d) => {
        if (d.type !== "session") return d.label;
        return d.label.toLowerCase().includes(q) ? truncate(d.label, 40) : "";
      });
    });

    // Zoom-to-fit: frame all nodes within the canvas so nothing clips off-edge.
    function fitView() {
      if (!data.nodes.length) return;
      const xs = data.nodes.map((n) => n.x), ys = data.nodes.map((n) => n.y);
      const minX = Math.min(...xs), maxX = Math.max(...xs);
      const minY = Math.min(...ys), maxY = Math.max(...ys);
      const w = (maxX - minX) || 1, h = (maxY - minY) || 1;
      const pad = 70;
      const scale = Math.min(4, Math.max(0.05, Math.min((width - pad * 2) / w, (height - pad * 2) / h)));
      const tx = width / 2 - scale * (minX + maxX) / 2;
      const ty = height / 2 - scale * (minY + maxY) / 2;
      svg.transition().duration(450).call(zoomBehavior.transform, zoomIdentity.translate(tx, ty).scale(scale));
    }
    // Fit once the simulation cools, with a fallback in case "end" is slow.
    sim.on("end", fitView);
    setTimeout(fitView, 1800);

    // Reset view → re-fit everything
    document.getElementById("graph-reset").addEventListener("click", fitView);

    // Resize
    window.addEventListener("resize", () => {
      width = container.clientWidth;
      height = container.clientHeight;
      sim.force("center", forceCenter(width / 2, height / 2));
      sim.force("x", forceX(width / 2).strength(0.03));
      sim.force("y", forceY(height / 2).strength(0.03));
      sim.alpha(0.3).restart();
    });
  </script>
  </div>
  <style>
    .gtab { padding:6px 12px; background:var(--panel); color:var(--text-dim); text-decoration:none; }
    .gtab:hover { background:var(--panel-2); color:var(--text); }
    .gtab[data-on="true"] { background:var(--amber); color:#241f17; font-weight:600; }
  </style>
</AppShell>
