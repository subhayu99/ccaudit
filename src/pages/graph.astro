---
import AppShell from "../layouts/AppShell.astro";
import Sidebar from "../components/Sidebar.astro";
import { type GraphData } from "../db/graph";
import { getHierarchyGraphData } from "../db/hierarchy-graph";
import { getDb } from "../db/init";
import { getLibraryTree, type LibraryTree } from "../db/library";

// One unified graph: the full repo → folder → session → topic dataset. All filtering
// (which node types are shown) happens client-side via the floating control panel — no tabs.
let dbError = "";
let graph: GraphData = { nodes: [], links: [] };
let tree: LibraryTree = { repos: [], totalCount: 0 };

const db = getDb();
try {
  graph = getHierarchyGraphData(db, { includeTopics: true });
  tree = getLibraryTree(db);
} catch (e) {
  dbError = e instanceof Error ? e.message : String(e);
}

const count = (t: string) => graph.nodes.filter((n) => n.type === t).length;

// Control-panel rows = legend + toggle in one. Same warm hues the renderer paints.
const types = [
  { type: "repo", label: "Repos", color: "#7fae7a", n: count("repo") },
  { type: "workdir", label: "Folders", color: "#cf9152", n: count("workdir") },
  { type: "session", label: "Sessions", color: "#9b82d6", n: count("session") },
  { type: "topic", label: "Topics", color: "#d2a85f", n: count("topic") },
];

// Passed to the client via a hidden element's data-* attribute (Astro escapes it).
// Avoids a <script type="application/json"> tag, which Vite's dev dependency scanner chokes on.
const graphJson = JSON.stringify(graph);
---
<AppShell title="ccaudit — graph">
  <Sidebar slot="sidebar" tree={tree} />
  <div slot="reader" class="flex flex-col h-screen p-5">
  {dbError && (
    <div class="rounded-lg p-3 mb-3 text-sm" style="background:rgba(180,60,60,.12); border:1px solid rgba(180,60,60,.4); color:#e0a0a0;">
      <strong>Couldn't load graph data:</strong> {dbError} — run <span class="font-mono-w">ccaudit reindex</span>.
    </div>
  )}

  <div class="flex items-center gap-3 mb-3 flex-wrap">
    <h1 class="font-serif text-2xl font-semibold mr-1" style="color:var(--text);">Graph</h1>
    <input
      id="graph-search"
      type="search"
      placeholder="Highlight nodes…"
      class="px-3 py-1.5 text-sm rounded-lg w-64 focus:outline-none"
      style="background:var(--panel); border:1px solid var(--border); color:var(--text);"
    />
    <span class="text-sm ml-auto hidden sm:inline" style="color:var(--text-faint);">drag · scroll to zoom · hover to focus · click to open</span>
  </div>

  <div
    id="graph-container"
    class="relative rounded-lg overflow-hidden flex-1"
    style="background:radial-gradient(ellipse 82% 72% at 50% 42%, var(--panel-2) 0%, var(--panel) 55%, var(--canvas) 100%); border:1px solid var(--border-soft);"
  >
    <svg id="graph-svg" width="100%" height="100%" style="display:block; cursor:grab;"></svg>

    <!-- Obsidian-style floating control panel: legend + per-type visibility toggle. -->
    <div id="graph-panel" class="graph-panel">
      <button id="panel-head" class="panel-head" type="button" aria-label="Toggle display panel">
        <span>Display</span><span id="panel-chev" class="chev">▾</span>
      </button>
      <div id="panel-body" class="panel-body">
        {types.map((t) => (
          <button class="ptype" data-type={t.type} data-on="true" type="button">
            <span class="pdot" style={`--c:${t.color}`}></span>
            <span class="plabel">{t.label}</span>
            <span class="pcount">{t.n}</span>
          </button>
        ))}
      </div>
    </div>

    <div
      id="graph-tooltip"
      class="pointer-events-none absolute hidden z-10 rounded-lg shadow-lg max-w-xs"
      style="background:#221f1a; color:var(--text); border:1px solid var(--border); padding:7px 11px; font-size:12.5px; line-height:1.4;"
    ></div>
    <button
      id="graph-reset"
      class="absolute bottom-3 right-3 px-3 py-1.5 text-xs font-medium rounded-lg"
      style="background:var(--raise); color:var(--text-dim); border:1px solid var(--border);"
    >
      Reset view
    </button>
  </div>

  <div id="graph-data" data-graph={graphJson} hidden></div>

  <script>
    // @ts-nocheck — client-side d3 viz glue; types relaxed for brevity.
    import { forceSimulation, forceManyBody, forceLink, forceCollide, forceX, forceY } from "d3-force";
    import { select } from "d3-selection";
    import { zoom, zoomIdentity } from "d3-zoom";
    import { drag } from "d3-drag";
    import { filterGraphByTypes } from "../lib/graph-filter";

    const fullData = JSON.parse(document.getElementById("graph-data").dataset.graph);
    const container = document.getElementById("graph-container");
    const svgEl = document.getElementById("graph-svg");
    const tooltip = document.getElementById("graph-tooltip");

    let width = container.clientWidth;
    let height = container.clientHeight;

    // Per-type visual style (warm palette, no blue): repo=green, folder/workdir=orange,
    // topic=amber, session=violet. Hubs get a serif label, a translucent halo, and a glow.
    const TYPE = {
      repo:    { color: "#7fae7a", hub: true,  glow: true,  r: (d) => 10 + Math.sqrt(d.workdirCount || 1) * 4 },
      topic:   { color: "#d2a85f", hub: true,  glow: true,  r: (d) => 9 + Math.sqrt(d.sessionCount || 1) * 4.5 },
      workdir: { color: "#cf9152", hub: true,  glow: true,  r: () => 7 },
      session: { color: "#9b82d6", hub: false, glow: false, r: (d) => 2.6 + Math.sqrt(d.messageCount || 1) * 0.22 },
    };
    const ts = (d) => TYPE[d.type] || TYPE.session;
    const labelDy = (d) => -ts(d).r(d) - 9;
    const AMBER = "#d2a85f";

    // Search-highlight state — declared up here because the label .text() callback reads it
    // at render time (a later `let` would be in its TDZ).
    let searchQuery = "";

    const svg = select(svgEl);
    const root = svg.append("g");
    const zoomBehavior = zoom().scaleExtent([0.1, 6]).on("zoom", (e) => root.attr("transform", e.transform));
    svg.call(zoomBehavior);

    // Soft glow for hubs (on the svg defs, persists across rebuilds).
    const defs = svg.append("defs");
    const f = defs.append("filter").attr("id", "glow").attr("x", "-70%").attr("y", "-70%").attr("width", "240%").attr("height", "240%");
    f.append("feGaussianBlur").attr("stdDeviation", "5").attr("result", "b");
    const fm = f.append("feMerge"); fm.append("feMergeNode").attr("in", "b"); fm.append("feMergeNode").attr("in", "SourceGraphic");

    // --- Visibility state (persisted, Obsidian-style) ---
    const ALL_TYPES = ["repo", "workdir", "session", "topic"];
    const LS_KEY = "ccaudit.graph.visibleTypes";
    function loadVisible() {
      try {
        const a = JSON.parse(localStorage.getItem(LS_KEY));
        if (Array.isArray(a) && a.length) return new Set(a.filter((t) => ALL_TYPES.includes(t)));
      } catch {}
      return new Set(ALL_TYPES);
    }
    const visible = loadVisible();
    const saveVisible = () => { try { localStorage.setItem(LS_KEY, JSON.stringify([...visible])); } catch {} };

    // --- Selections + sim, rebuilt on each toggle ---
    let link, node, label, sim, curLinks;

    function truncate(s, n) { return s && s.length > n ? s.slice(0, n - 1) + "…" : s || ""; }
    function labelText(d) {
      if (ts(d).hub) return d.label;
      return searchQuery && d.label.toLowerCase().includes(searchQuery) ? truncate(d.label, 40) : "";
    }
    function applyHighlight() {
      if (!node) return;
      if (!searchQuery) {
        node.style("opacity", 1);
        link.style("stroke-opacity", 0.14);
      } else {
        node.style("opacity", (d) => (d.label.toLowerCase().includes(searchQuery) ? 1 : 0.1));
        link.style("stroke-opacity", 0.04);
      }
    }
    function neighbors(d) {
      const s = new Set([d.id]);
      curLinks.forEach((l) => {
        const sid = l.source.id ?? l.source, tid = l.target.id ?? l.target;
        if (sid === d.id) s.add(tid);
        if (tid === d.id) s.add(sid);
      });
      return s;
    }
    const curve = (d) => {
      const dx = d.target.x - d.source.x, dy = d.target.y - d.source.y;
      const dr = Math.hypot(dx, dy) * 1.6;
      return `M${d.source.x},${d.source.y}A${dr},${dr} 0 0,1 ${d.target.x},${d.target.y}`;
    };

    function build(animate) {
      const filtered = filterGraphByTypes(fullData, visible);
      curLinks = filtered.links;
      root.selectAll("*").remove();

      link = root.append("g").selectAll("path").data(curLinks).join("path")
        .attr("fill", "none").attr("stroke", AMBER).attr("stroke-opacity", 0.14).attr("stroke-width", 1);

      node = root.append("g").selectAll("g").data(filtered.nodes, (d) => d.id).join("g").style("cursor", "pointer");
      node.filter((d) => ts(d).hub).append("circle").attr("r", (d) => ts(d).r(d) + 7)
        .attr("fill", (d) => ts(d).color).attr("fill-opacity", 0.16);
      node.append("circle")
        .attr("r", (d) => ts(d).r(d))
        .attr("fill", (d) => ts(d).color)
        .attr("fill-opacity", (d) => (ts(d).hub ? 1 : 0.62))
        .attr("stroke", (d) => (ts(d).hub ? "#ecca8e" : "none")).attr("stroke-opacity", 0.35)
        .attr("filter", (d) => (ts(d).glow ? "url(#glow)" : null));
      label = node.append("text").attr("class", "glabel")
        .attr("text-anchor", "middle").attr("dy", labelDy)
        .attr("font-size", (d) => (d.type === "session" ? 11 : 13.5))
        .attr("font-weight", (d) => (ts(d).hub ? 600 : 400))
        .style("paint-order", "stroke").style("pointer-events", "none")
        .text((d) => labelText(d));

      node
        .on("mouseover", function (event, d) {
          if (!searchQuery) {
            const nb = neighbors(d);
            node.style("opacity", (o) => (nb.has(o.id) ? 1 : 0.12));
            link.style("stroke-opacity", (l) => {
              const sid = l.source.id ?? l.source, tid = l.target.id ?? l.target;
              return sid === d.id || tid === d.id ? 0.55 : 0.03;
            });
          }
          select(this).select("text").text(truncate(d.label, 48)).attr("font-weight", 700);
          let meta;
          if (d.type === "topic") meta = `topic · ${d.sessionCount} session${d.sessionCount === 1 ? "" : "s"}`;
          else if (d.type === "repo") meta = `repo · ${d.workdirCount} folder${d.workdirCount === 1 ? "" : "s"}${d.remote ? ` · ${d.remote}` : ""}`;
          else if (d.type === "workdir") meta = `${d.existsOnDisk === false ? "⚠ deleted · " : "folder · "}${d.workdirPath || ""}`;
          else meta = `${d.messageCount || 0} msg${d.messageCount === 1 ? "" : "s"}${d.compactCount > 0 ? ` · ${d.compactCount} compact` : ""}`;
          tooltip.innerHTML = `<div style="font-weight:600;color:var(--text);">${truncate(d.label, 80)}</div><div style="color:var(--text-dim);font-size:11.5px;word-break:break-all;">${truncate(meta, 120)}</div>`;
          tooltip.classList.remove("hidden");
        })
        .on("mousemove", function (event) {
          const rect = container.getBoundingClientRect();
          tooltip.style.left = event.clientX - rect.left + 14 + "px";
          tooltip.style.top = event.clientY - rect.top + 14 + "px";
        })
        .on("mouseout", function (event, d) {
          applyHighlight();
          select(this).select("text").text(labelText(d)).attr("font-weight", ts(d).hub ? 600 : 400);
          tooltip.classList.add("hidden");
        })
        .on("click", (event, d) => {
          if (event.defaultPrevented) return;
          if (d.type === "session") window.location.href = "/s/" + d.sessionId;
          else if (d.type === "topic") window.location.href = "/?topic=" + d.id.slice(6);
          else if (d.type === "repo") window.location.href = "/?repo=" + encodeURIComponent(d.id.slice(5));
          else if (d.type === "workdir") window.location.href = "/?workdir=" + encodeURIComponent(d.workdirPath || d.id.slice(9));
        })
        .call(drag()
          .on("start", (event, d) => { if (!event.active) sim.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
          .on("drag", (event, d) => { d.fx = event.x; d.fy = event.y; })
          .on("end", (event, d) => { if (!event.active) sim.alphaTarget(0); d.fx = null; d.fy = null; }));

      sim = forceSimulation(filtered.nodes)
        .force("charge", forceManyBody().strength((d) => (ts(d).hub ? -300 : -22)))
        .force("link", forceLink(curLinks).id((d) => d.id)
          .distance((l) => (l.kind === "session-topic" ? 70 : l.kind === "workdir-repo" || l.kind === "session-repo" ? 55 : 40)).strength(0.5))
        .force("x", forceX(() => width / 2).strength(0.05))
        .force("y", forceY(() => height / 2).strength(0.06))
        .force("collide", forceCollide((d) => ts(d).r(d) + (ts(d).hub ? 14 : 2)));

      const draw = () => { link.attr("d", curve); node.attr("transform", (d) => `translate(${d.x},${d.y})`); };
      sim.on("tick", draw);
      if (animate) {
        sim.alpha(0.9).restart();
        sim.on("end", () => fitView(450));
        setTimeout(() => fitView(450), 1500);
      } else {
        for (let i = 0; i < 300; i++) sim.tick();
        sim.stop();
        draw();
        fitView(0);
      }
      applyHighlight();
    }

    function fitView(ms) {
      const bb = root.node().getBBox();
      if (!bb.width || !bb.height) return;
      const pad = 80;
      const k = Math.min((width - pad * 2) / bb.width, (height - pad * 2) / bb.height, 2.4);
      const tx = width / 2 - k * (bb.x + bb.width / 2);
      const ty = height / 2 - k * (bb.y + bb.height / 2);
      svg.transition().duration(ms ?? 500).call(zoomBehavior.transform, zoomIdentity.translate(tx, ty).scale(k));
    }

    // --- Control panel wiring ---
    const rows = [...document.querySelectorAll(".ptype")];
    const syncRow = (row) => row.setAttribute("data-on", visible.has(row.dataset.type) ? "true" : "false");
    rows.forEach((row) => {
      syncRow(row); // reflect persisted state
      row.addEventListener("click", () => {
        const t = row.dataset.type;
        if (visible.has(t)) visible.delete(t); else visible.add(t);
        syncRow(row);
        saveVisible();
        build(true);
      });
    });

    const panel = document.getElementById("graph-panel");
    const PANEL_LS = "ccaudit.graph.panelCollapsed";
    if (localStorage.getItem(PANEL_LS) === "1") panel.classList.add("collapsed");
    document.getElementById("panel-head").addEventListener("click", () => {
      panel.classList.toggle("collapsed");
      try { localStorage.setItem(PANEL_LS, panel.classList.contains("collapsed") ? "1" : "0"); } catch {}
    });

    // Search (rebound to the current selection each time it fires).
    const searchInput = document.getElementById("graph-search");
    searchInput.addEventListener("input", () => {
      searchQuery = searchInput.value.trim().toLowerCase();
      applyHighlight();
      if (label) label.text(labelText);
    });

    document.getElementById("graph-reset").addEventListener("click", () => fitView(500));
    window.addEventListener("resize", () => {
      width = container.clientWidth;
      height = container.clientHeight;
      if (sim) sim.alpha(0.2).restart();
    });

    build(false); // initial render
  </script>
  </div>
  <style>
    .graph-panel { position:absolute; top:12px; right:12px; z-index:10; width:188px; background:color-mix(in srgb, var(--panel) 88%, transparent); border:1px solid var(--border); border-radius:12px; box-shadow:0 12px 34px rgba(0,0,0,.35); backdrop-filter:blur(8px); overflow:hidden; font-size:13px; }
    .panel-head { display:flex; align-items:center; justify-content:space-between; width:100%; padding:8px 12px; background:transparent; border:0; cursor:pointer; color:var(--text-dim); font-weight:600; letter-spacing:.02em; }
    .panel-head:hover { color:var(--text); }
    .chev { transition:transform .18s ease; font-size:11px; }
    .graph-panel.collapsed .panel-body { display:none; }
    .graph-panel.collapsed .chev { transform:rotate(-90deg); }
    .panel-body { padding:4px; display:flex; flex-direction:column; gap:1px; border-top:1px solid var(--border-soft); }
    .ptype { display:flex; align-items:center; gap:9px; width:100%; padding:6px 8px; background:transparent; border:0; border-radius:8px; cursor:pointer; transition:background .12s, opacity .12s; }
    .ptype:hover { background:var(--panel-2); }
    .pdot { width:11px; height:11px; border-radius:999px; background:var(--c); flex:none; }
    .plabel { color:var(--text); flex:1; text-align:left; }
    .pcount { color:var(--text-faint); font-variant-numeric:tabular-nums; font-size:12px; }
    .ptype[data-on="false"] { opacity:.42; }
    .ptype[data-on="false"] .pdot { background:transparent; box-shadow:inset 0 0 0 2px var(--c); }
    /* Serif labels — adapt to theme (light text + canvas-colored stroke for legibility). */
    :global(#graph-svg .glabel) {
      font-family: Georgia, "Times New Roman", serif;
      fill: var(--text);
      stroke: var(--canvas);
      stroke-width: 3.2px;
    }
  </style>
</AppShell>
