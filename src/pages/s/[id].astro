---
import Base from "../../layouts/Base.astro";
import { openDb } from "../../db/init";
import { getSession } from "../../db/sessions";
import { getSessionMessages } from "../../db/messages";
import { formatTimestamp, shortSessionId, truncate } from "../../lib/render";
import { INDEX_DB_PATH } from "../../paths";
import MessageUser from "../../components/MessageUser.astro";
import MessageAssistant from "../../components/MessageAssistant.astro";
import ToolUseChip from "../../components/ToolUseChip.astro";
import ToolResultChip from "../../components/ToolResultChip.astro";
import AttachmentChip from "../../components/AttachmentChip.astro";
import CompactWaypoint from "../../components/CompactWaypoint.astro";
import SidechainBlock from "../../components/SidechainBlock.astro";
import { classifyMessage } from "../../lib/message-kind";

const { id } = Astro.params;
if (!id) {
  return new Response("missing id", { status: 400 });
}
// The reader now lives in the 3-pane shell; keep old links working.
return Astro.redirect(`/?session=${id}`);

const db = openDb(INDEX_DB_PATH);
const session = getSession(db, id);
const messages = session ? getSessionMessages(db, id) : [];
db.close();

if (!session) {
  return new Response("session not found", { status: 404 });
}

// Classify once, reuse for rendering + counts.
const classified = messages.map((m) => ({ m, kind: classifyMessage(m) }));
const noiseCount = classified.filter((c) => c.kind === "noise").length;

const compactIndex = new Map<number, number>(); // lineNo -> compact #
let compactN = 0;
for (const m of messages) {
  if (m.isCompactSummary) {
    compactN += 1;
    compactIndex.set(m.lineNo, compactN);
  }
}

type Landmark = { lineNo: number; kind: "user" | "compact"; label: string };
const landmarks: Landmark[] = [];
for (const { m, kind } of classified) {
  if (kind === "user-text") {
    landmarks.push({ lineNo: m.lineNo, kind: "user", label: truncate(m.textContent ?? "", 42) });
  } else if (kind === "compact-summary") {
    landmarks.push({ lineNo: m.lineNo, kind: "compact", label: `Compact #${compactIndex.get(m.lineNo) ?? 0}` });
  }
}

const title = session.aiTitle ?? session.firstPrompt ?? `Session ${shortSessionId(session.id)}`;
---
<Base title={`ccaudit — ${title}`}>
  <div class="mb-6">
    <div class="text-slate-500 text-sm">
      <a href="/" class="hover:underline">← All sessions</a>
      <span class="mx-2">·</span>
      <a href={`/projects`} class="hover:underline">{session.projectLabel}</a>
    </div>
    <h1 class="text-2xl font-bold mt-2">{title}</h1>
    <div class="text-sm text-slate-500 mt-1">
      <span>{formatTimestamp(session.startedAt)} → {formatTimestamp(session.lastActivity)}</span>
      <span class="mx-2">·</span>
      <span>{session.messageCount} messages</span>
      {session.compactCount > 0 && (
        <>
          <span class="mx-2">·</span>
          <span class="text-amber-700">{session.compactCount} compact event{session.compactCount === 1 ? "" : "s"}</span>
        </>
      )}
      {session.gitBranch && (
        <>
          <span class="mx-2">·</span>
          <span class="font-mono text-xs">{session.gitBranch}</span>
        </>
      )}
    </div>
    <div class="text-xs text-slate-400 mt-1 font-mono">{session.id}</div>
  </div>

  <div class="mb-4 flex flex-wrap gap-4 items-center">
    <button
      id="resume-btn"
      class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors"
    >
      Resume this session
    </button>
    <label class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-300 cursor-pointer select-none">
      <input type="checkbox" id="toggle-turns" class="rounded" />
      User turns only
    </label>
    <label class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-300 cursor-pointer select-none">
      <input type="checkbox" id="toggle-system" class="rounded" />
      Show system messages {noiseCount > 0 && <span class="text-slate-400">({noiseCount})</span>}
    </label>
  </div>

  <dialog id="resume-dialog" class="rounded-xl shadow-2xl border border-slate-200 p-0 backdrop:bg-black/40 max-w-lg w-full">
    <div class="p-6">
      <h3 class="text-lg font-bold mb-4">Resume this session</h3>
      <p class="text-sm text-slate-600 mb-3">Run this in a terminal:</p>
      <pre id="resume-command" class="bg-slate-900 text-green-400 rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap select-all"></pre>
      <div class="text-xs text-slate-500 mt-3 space-y-1">
        <div>Working directory: <span class="font-mono">{session.cwd ?? session.projectDir}</span></div>
        {session.gitBranch && <div>Branch when last active: <span class="font-mono">{session.gitBranch}</span></div>}
        <div>Last activity: {formatTimestamp(session.lastActivity)}</div>
      </div>
      <div class="flex gap-3 mt-6">
        <button id="copy-btn" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">
          Copy command
        </button>
        <button id="close-btn" class="px-4 py-2 text-sm font-semibold text-slate-700 bg-slate-200 rounded-lg hover:bg-slate-300 transition-colors">
          Cancel
        </button>
      </div>
    </div>
  </dialog>

  <script define:vars={{ sessionId: session.id, sessionCwd: session.cwd ?? session.projectDir }}>
    const dialog = document.getElementById('resume-dialog');
    const commandEl = document.getElementById('resume-command');
    const resumeBtn = document.getElementById('resume-btn');
    const copyBtn = document.getElementById('copy-btn');
    const closeBtn = document.getElementById('close-btn');

    const command = `cd ${sessionCwd}\nclaude --resume ${sessionId}`;
    commandEl.textContent = command;

    resumeBtn.addEventListener('click', () => dialog.showModal());
    closeBtn.addEventListener('click', () => dialog.close());
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(command).then(() => {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy command'; }, 1500);
      });
    });
  </script>

  <div class="flex gap-6 items-start">
    <!-- Minimap rail: sticky, hidden on small screens -->
    <nav class="hidden lg:block sticky top-6 w-56 flex-shrink-0 max-h-[80vh] overflow-y-auto text-sm" aria-label="Session timeline">
      <div class="text-xs uppercase text-slate-400 font-semibold mb-2 px-2">Timeline</div>
      <ol class="space-y-0.5">
        {landmarks.map((lm) => (
          <li>
            <a
              href={`#line-${lm.lineNo}`}
              class={`block px-2 py-1 rounded truncate hover:bg-slate-100 ${lm.kind === "compact" ? "text-amber-700 font-medium" : "text-slate-600"}`}
              title={lm.label}
            >
              {lm.kind === "compact" ? "🗜 " : ""}{lm.label}
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <!-- Messages column -->
    <div id="messages" class="space-y-3 flex-1 min-w-0">
      {classified.map(({ m, kind }) => (
        <div id={`line-${m.lineNo}`} data-kind={kind}>
          {kind === "compact-summary" ? (
            <CompactWaypoint message={m} index={compactIndex.get(m.lineNo) ?? 0} />
          ) : kind === "sidechain" ? (
            <SidechainBlock message={m} />
          ) : kind === "user-text" ? (
            <MessageUser message={m} />
          ) : kind === "assistant-text" ? (
            <MessageAssistant message={m} />
          ) : kind === "tool-use" ? (
            <ToolUseChip message={m} />
          ) : kind === "tool-result" ? (
            <ToolResultChip message={m} />
          ) : kind === "attachment" ? (
            <AttachmentChip message={m} />
          ) : (
            <div class="px-2 py-0.5 text-xs text-slate-400 dark:text-slate-600 font-mono">
              line {m.lineNo} · {m.type}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>

  <style is:global>
    /* Hide internal/system messages by default; toggles reveal or focus content. */
    #messages [data-kind="noise"] { display: none; }
    #messages.show-system [data-kind="noise"] { display: block; }
    #messages.turns-only [data-kind="tool-use"],
    #messages.turns-only [data-kind="tool-result"],
    #messages.turns-only [data-kind="attachment"],
    #messages.turns-only [data-kind="noise"] { display: none; }
    /* Smooth scrolling + anchor offset so landmarks land below the header */
    html { scroll-behavior: smooth; }
    #messages > div[id^="line-"] { scroll-margin-top: 1rem; }
  </style>

  <script>
    const msgs = document.getElementById("messages");
    const turns = document.getElementById("toggle-turns") as HTMLInputElement | null;
    const system = document.getElementById("toggle-system") as HTMLInputElement | null;
    turns?.addEventListener("change", () => msgs?.classList.toggle("turns-only", turns.checked));
    system?.addEventListener("change", () => msgs?.classList.toggle("show-system", system.checked));
  </script>

  <script>
    // @ts-nocheck — client-side minimap highlight glue; types relaxed for brevity.
    // Highlight nearest landmark on scroll using IntersectionObserver.
    const links = Array.from(document.querySelectorAll('nav[aria-label="Session timeline"] a'));
    if (links.length > 0) {
      const byLine = new Map(links.map((a) => [a.getAttribute("href"), a]));
      const obs = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            const link = byLine.get("#" + e.target.id);
            if (link) {
              links.forEach((l) => l.classList.remove("bg-slate-200", "dark:bg-slate-700"));
              link.classList.add("bg-slate-200", "dark:bg-slate-700");
            }
          }
        }
      }, { rootMargin: "-10% 0px -80% 0px" });
      document.querySelectorAll('#messages > div[id^="line-"]').forEach((el) => obs.observe(el));
    }
  </script>
</Base>
