---
import AppShell from "../layouts/AppShell.astro";
import Sidebar from "../components/Sidebar.astro";
import DbErrorPanel from "../components/DbErrorPanel.astro";
import { getDb } from "../db/init";
import { getLibraryTree, type LibraryTree } from "../db/library";
import { resolveRange } from "../db/date-range";

const q = Astro.url.searchParams.get("q")?.trim() ?? "";
const range = resolveRange(Astro.cookies.get("ccaudit-range")?.value, Date.now());
let dbError = "";
let tree: LibraryTree = { repos: [], totalCount: 0 };
const db = getDb();
try { tree = getLibraryTree(db, range); } catch (e) { dbError = e instanceof Error ? e.message : String(e); }
---
<AppShell title={q ? `ccaudit — ask: ${q}` : "ccaudit — ask"}>
  <Sidebar slot="sidebar" tree={tree} />
  <div slot="reader" class="p-8 max-w-[820px]">
    {dbError ? <DbErrorPanel message={dbError} /> : (
      <>
        <h1 class="font-serif text-2xl font-semibold mb-1" style="color:var(--text);">Ask your history</h1>
        <p class="text-[13.5px] mb-5" style="color:var(--text-dim);">Ask a question; ccaudit retrieves relevant moments from your sessions and has Claude answer with citations you can click back to.</p>

        <form id="ask-form" class="mb-3">
          <div class="flex gap-2">
            <input id="ask-q" type="search" value={q} placeholder="e.g. when did I set up the Stripe webhook?" autocomplete="off" autofocus
              class="flex-1 px-4 py-2.5 text-base rounded-lg focus:outline-none"
              style="background:var(--panel); border:1px solid var(--border); color:var(--text);" />
            <button type="submit" id="ask-btn" class="px-5 py-2.5 text-sm font-semibold rounded-lg" style="background:var(--amber); color:#241f17;">Ask</button>
          </div>
        </form>

        <div id="ask-status" class="text-[13px] mb-4" style="color:var(--text-faint);"></div>
        <div id="ask-answer" class="prose-warm" style="font-size:14.5px;"></div>
        <div id="ask-sources" class="mt-6"></div>

        <p class="text-[11.5px] mt-8" style="color:var(--text-faint);">Answers are generated by <span class="font-mono-w">claude -p</span> over your top text matches — a few cents and ~30s per question. Claude may miss things not surfaced by search.</p>
      </>
    )}
  </div>

  <script is:inline define:vars={{ initialQ: q }}>
    const form = document.getElementById("ask-form");
    if (form) {
      const input = document.getElementById("ask-q");
      const btn = document.getElementById("ask-btn");
      const statusEl = document.getElementById("ask-status");
      const answerEl = document.getElementById("ask-answer");
      const sourcesEl = document.getElementById("ask-sources");
      let busy = false;

      const esc = (s) => s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));

      function renderAnswer(md, hrefByN) {
        // Lightweight markdown: escape, then code/bold/headers/lists, citations, paragraphs.
        let h = esc(md);
        h = h.replace(/`([^`]+)`/g, '<code>$1</code>');
        h = h.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
        h = h.replace(/\[(\d+)\]/g, (m, n) => {
          const href = hrefByN[n];
          return href ? `<a class="cite" href="${href}">[${n}]</a>` : m;
        });
        // paragraphs + line breaks
        h = h.split(/\n{2,}/).map((p) => {
          const lines = p.split(/\n/);
          if (lines.every((l) => /^\s*[-*]\s+/.test(l))) {
            return "<ul>" + lines.map((l) => "<li>" + l.replace(/^\s*[-*]\s+/, "") + "</li>").join("") + "</ul>";
          }
          return "<p>" + lines.join("<br>") + "</p>";
        }).join("");
        return h;
      }

      function renderSources(sources, heading) {
        if (!sources || !sources.length) return "";
        const items = sources.map((s) =>
          `<a class="src" href="/?session=${s.sessionId}#m${s.lineNo}">` +
            `<div class="src-top"><span class="src-n">[${s.n}]</span> <span class="src-t">${esc(s.title)}</span> <span class="src-l">line ${s.lineNo}</span></div>` +
            (s.snippet ? `<div class="src-snip">${s.snippet}</div>` : "") +
          `</a>`
        ).join("");
        return '<div class="src-head">' + (heading || "Sources") + "</div>" + items;
      }

      async function post(payload) {
        const res = await fetch("/api/ask", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
        return { res, data: await res.json() };
      }

      async function ask(q) {
        if (busy || !q) return;
        busy = true; btn.disabled = true;
        answerEl.innerHTML = ""; sourcesEl.innerHTML = "";
        statusEl.textContent = "Searching your history…";
        try {
          // Phase 1 — show the matched chats immediately, while Claude reads them.
          const { res: rRes, data: rData } = await post({ q, mode: "retrieve" });
          if (!rRes.ok) { statusEl.textContent = "Error: " + (rData.error || rRes.status); return; }
          const matches = rData.sources || [];
          if (!matches.length) { statusEl.textContent = "No matching messages found in your history."; return; }
          sourcesEl.innerHTML = renderSources(matches, "Matched " + matches.length + " moments");
          statusEl.innerHTML = rData.cached
            ? '<span class="cached-badge">⚡ cached</span> retrieving…'
            : '<span class="thinking">Claude is reading the matches<span class="dots"></span></span>';

          // Phase 2 — synthesize the answer (served from cache when fresh → instant).
          const { res, data } = await post({ q });
          if (!res.ok) { statusEl.textContent = "Error: " + (data.error || res.status); return; }
          if (data.note) { statusEl.textContent = data.note; sourcesEl.innerHTML = ""; return; }
          statusEl.innerHTML = data.cached ? '<span class="cached-badge">⚡ cached answer</span>' : "";
          const hrefByN = {};
          (data.sources || []).forEach((s) => { hrefByN[String(s.n)] = `/?session=${s.sessionId}#m${s.lineNo}`; });
          answerEl.innerHTML = renderAnswer(data.answer || "(no answer)", hrefByN);
          sourcesEl.innerHTML = renderSources(data.sources, "Sources");
        } catch (err) {
          statusEl.textContent = "Error: " + (err && err.message ? err.message : err);
        } finally {
          busy = false; btn.disabled = false;
        }
      }

      form.addEventListener("submit", (e) => { e.preventDefault(); const v = input.value.trim(); if (v) { history.replaceState(null, "", "/ask?q=" + encodeURIComponent(v)); ask(v); } });
      if (initialQ) ask(initialQ);
    }
  </script>

  <!-- is:global because the answer/source/status nodes are injected via innerHTML at runtime and
       never receive Astro's scope attribute. Every rule is namespaced by the page's #ask-* ids so
       nothing leaks. -->
  <style is:global>
    #ask-answer p { margin: 0 0 12px; color: var(--text); line-height: 1.65; }
    #ask-answer ul { margin: 0 0 12px 1.2em; color: var(--text); }
    #ask-answer li { margin: 3px 0; }
    #ask-answer code { background: var(--raise); border-radius: 4px; padding: 1px 5px; font-family: var(--mono); font-size: 12.5px; }
    #ask-answer .cite { color: var(--amber-bright); text-decoration: none; font-weight: 600; font-size: 11px; vertical-align: super; padding: 0 1px; }
    #ask-answer .cite:hover { text-decoration: underline; }
    #ask-sources .src-head { font-size: 10.5px; text-transform: uppercase; letter-spacing: .1em; color: var(--text-faint); margin: 4px 0 9px; }
    #ask-sources .src { display: block; padding: 9px 12px; border-radius: 9px; text-decoration: none; background: var(--panel); border: 1px solid var(--border-soft); margin-bottom: 7px; transition: background .12s, border-color .12s; }
    #ask-sources .src:hover { background: var(--panel-2); border-color: var(--border); }
    #ask-sources .src-top { display: flex; align-items: baseline; gap: 8px; }
    #ask-sources .src-n { color: var(--amber); font-family: var(--mono); font-size: 12px; flex: none; }
    #ask-sources .src-t { color: var(--text); font-size: 13.5px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    #ask-sources .src-l { color: var(--text-faint); font-size: 11px; font-family: var(--mono); margin-left: auto; flex: none; }
    #ask-sources .src-snip { margin-top: 5px; color: var(--text-dim); font-size: 12px; line-height: 1.55; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
    #ask-sources .src-snip mark { background: transparent; color: var(--amber-bright); font-weight: 600; padding: 0; }
    #ask-status .cached-badge { color: var(--c-green); font-family: var(--mono); font-size: 11.5px; }
    #ask-status .thinking { color: var(--text-faint); }
    #ask-status .dots::after { content: "…"; animation: askdots 1.2s steps(4, end) infinite; }
    @keyframes askdots { 0% { content: ""; } 25% { content: "."; } 50% { content: ".."; } 75% { content: "..."; } 100% { content: ""; } }
  </style>
</AppShell>
