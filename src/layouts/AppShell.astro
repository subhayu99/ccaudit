---
// src/layouts/AppShell.astro — adaptive shell.
//  - with a "list" slot  → 3-pane (sidebar | list | reader)  [browse]
//  - without            → 2-pane (sidebar | wide main)       [graph/search/projects]
import "../styles/global.css";
interface Props { title?: string; }
const { title = "ccaudit" } = Astro.props;
const hasList = Astro.slots.has("list");
const cols = hasList ? "264px 372px 1fr" : "264px 1fr";
---
<html lang="en" class="theme-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline>
      // dark-first; persist user choice
      try {
        const t = localStorage.getItem("ccaudit-theme");
        document.documentElement.classList.toggle("theme-light", t === "light");
      } catch {}
    </script>
  </head>
  <body class="m-0" style="background:var(--canvas); color:var(--text); font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Inter,Roboto,sans-serif;">
    <div class="grid h-screen overflow-hidden" style={`grid-template-columns: ${cols};`}>
      <aside class="overflow-y-auto" style="background:var(--panel); border-right:1px solid var(--border-soft);">
        <slot name="sidebar" />
      </aside>
      {hasList && (
        <section class="overflow-hidden flex flex-col" style="background:var(--panel-2); border-right:1px solid var(--border-soft);">
          <slot name="list" />
        </section>
      )}
      <main class="overflow-y-auto" style="background:var(--canvas);">
        <slot name="reader" />
      </main>
    </div>
    <slot />
  </body>
</html>
