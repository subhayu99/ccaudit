---
// src/layouts/AppShell.astro — adaptive, responsive shell.
//  desktop ≥900px: 3-pane (sidebar | list | reader) or 2-pane (sidebar | main)
//  mobile  <900px: sidebar becomes an off-canvas drawer; one content pane shows
//                  (reader if a session/page is in focus, else the list).
import "../styles/global.css";
interface Props { title?: string; mobileMain?: "list" | "reader"; }
const { title = "ccaudit", mobileMain = "list" } = Astro.props;
const hasList = Astro.slots.has("list");
// Column widths come from CSS vars so the collapse toggles (html.nav-rail / html.list-collapsed)
// can shrink the sidebar to an icon rail and hide the list, giving the reader the width.
const cols = hasList ? "var(--cs,264px) var(--cl,372px) 1fr" : "var(--cs,264px) 1fr";
const mobileFocus = hasList ? mobileMain : "reader";
---
<html lang="en" class="theme-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-mark.png" />
    <title>{title}</title>
    <script is:inline>
      try {
        const t = localStorage.getItem("ccaudit-theme");
        document.documentElement.classList.toggle("theme-light", t === "light");
        // Apply persisted panel-collapse state before paint (no flash).
        document.documentElement.classList.toggle("nav-rail", localStorage.getItem("ccaudit-nav-rail") === "1");
        document.documentElement.classList.toggle("list-collapsed", localStorage.getItem("ccaudit-list-collapsed") === "1");
      } catch {}
    </script>
  </head>
  <body class="m-0" style="background:var(--canvas); color:var(--text); font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Inter,Roboto,sans-serif;">
    <div class="mobile-bar">
      <button id="drawer-toggle" aria-label="menu" class="hamburger">☰</button>
      <span class="font-serif" style="font-size:17px; font-weight:600; color:var(--text);">ccaudit</span>
    </div>
    <div class="drawer-backdrop" id="drawer-backdrop"></div>
    <div class="shell-grid" data-mobile={mobileFocus} style={`grid-template-columns: ${cols};`}>
      <aside class="shell-sidebar" style="background:var(--panel); border-right:1px solid var(--border-soft);">
        <slot name="sidebar" />
      </aside>
      {hasList && (
        <section class="shell-list" style="background:var(--panel-2); border-right:1px solid var(--border-soft);">
          <slot name="list" />
        </section>
      )}
      <main class="shell-reader" style="background:var(--canvas);">
        <slot name="reader" />
      </main>
    </div>
    {hasList && <button id="list-toggle" class="list-toggle" aria-label="Show or hide the session list" title="Show/hide the session list"></button>}
    <slot />

    <style>
      .shell-grid { display:grid; height:100vh; overflow:hidden; }
      .shell-sidebar { overflow-y:auto; }
      .shell-list { overflow:hidden; display:flex; flex-direction:column; }
      .shell-reader { overflow-y:auto; }
      /* Collapse states (persisted on <html>). */
      html.nav-rail { --cs:56px; }
      /* Collapse the list by zeroing its track + clipping — NOT display:none, which would
         drop it from the grid and let the reader auto-place into the now-empty 0px track. */
      html.list-collapsed { --cl:0px; }
      html.list-collapsed .shell-list { border-right:none; }
      /* Handle straddling the list↔reader divider; collapses/expands the list. */
      .list-toggle { position:fixed; top:16px; left:calc(var(--cs,264px) + var(--cl,372px)); transform:translateX(-50%); z-index:25;
        width:24px; height:24px; border-radius:7px; background:var(--panel); border:1px solid var(--border);
        color:var(--text-dim); cursor:pointer; font-size:12px; line-height:1; transition:left .16s ease, color .12s; }
      .list-toggle:hover { color:var(--text); background:var(--panel-2); }
      .list-toggle::before { content:"⇤"; }
      html.list-collapsed .list-toggle::before { content:"⇥"; }
      .mobile-bar { display:none; align-items:center; gap:12px; height:52px; padding:0 14px; border-bottom:1px solid var(--border-soft); background:var(--panel); position:sticky; top:0; z-index:30; }
      .hamburger { background:none; border:none; color:var(--text); font-size:20px; cursor:pointer; line-height:1; padding:4px 6px; }
      .drawer-backdrop { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:35; }

      @media (max-width: 900px) {
        .mobile-bar { display:flex; }
        .shell-grid { grid-template-columns: 1fr !important; height:calc(100vh - 52px); }
        .shell-sidebar { position:fixed; top:0; bottom:0; left:0; width:264px; z-index:40; transform:translateX(-100%); transition:transform .2s ease; }
        body.drawer-open .shell-sidebar { transform:none; }
        body.drawer-open .drawer-backdrop { display:block; }
        .shell-grid[data-mobile="list"] .shell-reader { display:none; }
        .shell-grid[data-mobile="reader"] .shell-list { display:none; }
        .shell-list, .shell-reader { border-right:none !important; }
        .list-toggle { display:none; }
        html.nav-rail { --cs:264px; } /* rail is a desktop affordance; full sidebar on mobile */
      }
    </style>
    <script is:inline>
      (function () {
        var t = document.getElementById("drawer-toggle");
        var bd = document.getElementById("drawer-backdrop");
        function close() { document.body.classList.remove("drawer-open"); }
        if (t) t.addEventListener("click", function () { document.body.classList.toggle("drawer-open"); });
        if (bd) bd.addEventListener("click", close);
        // close the drawer when a sidebar link is tapped
        document.querySelectorAll(".shell-sidebar a").forEach(function (a) {
          a.addEventListener("click", close);
        });
        // List collapse — hide the session-list pane so the reader takes the width (persisted).
        var lt = document.getElementById("list-toggle");
        if (lt) lt.addEventListener("click", function () {
          var on = document.documentElement.classList.toggle("list-collapsed");
          try { localStorage.setItem("ccaudit-list-collapsed", on ? "1" : "0"); } catch (e) {}
        });
        // Sidebar icon-rail toggle. Two entry points, one state (no stacked buttons):
        //  • #rail-toggle (header) collapses when expanded.
        //  • #logo-expand (the logo) expands when collapsed — Gemini-style hover-to-expand.
        document.addEventListener("click", function (e) {
          var html = document.documentElement;
          var rt = e.target.closest && e.target.closest("#rail-toggle");
          var lg = e.target.closest && e.target.closest("#logo-expand");
          if (!rt && !lg) return;
          // The logo only acts as expand, and only while collapsed; otherwise it's inert.
          if (lg && !rt && !html.classList.contains("nav-rail")) return;
          var on = html.classList.toggle("nav-rail");
          try { localStorage.setItem("ccaudit-nav-rail", on ? "1" : "0"); } catch (e2) {}
        });
      })();
    </script>
  </body>
</html>
