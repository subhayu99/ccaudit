---
// src/components/Sidebar.astro
import type { LibraryTree } from "../db/library";
import type { TopicSummary } from "../db/topics";
import { rangeLabel } from "../db/date-range";
import { isJobRunning } from "../lib/jobs";
interface Props { tree: LibraryTree; topics?: TopicSummary[]; activeRepo?: string; activeWorkdir?: string; activeTopic?: number; mode?: string; }
const { tree, topics = [], activeRepo, activeWorkdir, activeTopic, mode } = Astro.props;
// Global date-range filter (persisted in the ccaudit-range cookie). Scopes list/search/ask.
const rangeToken = Astro.cookies.get("ccaudit-range")?.value ?? "all";
const RANGES = [{ key: "all", label: "All" }, { key: "7d", label: "7d" }, { key: "30d", label: "30d" }, { key: "custom", label: "Custom" }];
const isCustom = rangeToken.startsWith("custom:");
const activeRange = RANGES.some((r) => r.key === rangeToken) ? rangeToken : isCustom ? "custom" : "all";
// Pre-fill the custom date inputs (YYYY-MM-DD) when a custom range is active.
const isoDay = (ms: string) => {
  const d = new Date(Number(ms));
  return Number.isNaN(d.getTime()) ? "" : `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
};
const [, cf = "", ct = ""] = isCustom ? rangeToken.split(":") : [];
const customFrom = isCustom ? isoDay(cf) : "";
const customTo = isCustom ? isoDay(ct) : "";
// Long-running AI jobs (process-wide). Render the buttons mid-run on EVERY page so navigating away
// and back still shows progress and the action can't be re-fired.
const clusterRunning = isJobRunning("cluster");
const nameRunning = isJobRunning("name");
---
<div id="topbar-progress" aria-hidden="true"></div>
<div class="flex flex-col h-full" style="color:var(--text-dim);">
  <div class="brand-row flex items-center gap-2 px-4 pt-4 pb-3">
    <button id="logo-expand" class="brand-logo shrink-0" title="Expand sidebar" aria-label="Expand sidebar">
      <img src="/logo.png" alt="ccaudit" width="24" height="24" class="rounded-md" style="background:#1E1915; object-fit:contain;" />
      <span class="expand-ico" aria-hidden="true">→|</span>
    </button>
    <h1 class="font-serif text-[18px] font-semibold brand-name rail-hide" style="color:var(--text);">ccaudit</h1>
    <button id="rail-toggle" class="rail-toggle ml-auto" title="Collapse sidebar" aria-label="Collapse sidebar"></button>
  </div>
  <a href="/search" data-open-cmdk class="mx-3 mb-3 flex items-center gap-2 px-2.5 py-1.5 rounded-lg text-[13px]"
     style="background:var(--canvas); border:1px solid var(--border); color:var(--text-faint); text-decoration:none; cursor:pointer;">
    <span class="ico">⚲</span><span class="rail-hide">Search history…</span>
    <span class="ml-auto font-mono-w text-[11px] px-1.5 rounded rail-hide" style="background:var(--raise); border:1px solid var(--border);">⌘K</span>
  </a>
  <div class="px-3 mb-2 rail-hide">
    <div class="flex items-center mb-1">
      <span class="text-[10px] tracking-wider uppercase font-semibold" style="color:var(--text-faint);">Date range</span>
      {activeRange === "custom" && <span class="ml-auto text-[10.5px] font-mono-w" style="color:var(--amber-bright);">{rangeLabel(rangeToken)}</span>}
    </div>
    <div class="range-row" id="range-ctl">
      {RANGES.map((r) => <button type="button" class="rbtn" data-range={r.key} data-on={activeRange === r.key}>{r.label}</button>)}
    </div>
    <div id="range-custom" class="range-custom" hidden={activeRange !== "custom"}>
      <label class="rc-lbl">From<input type="date" id="rc-from" value={customFrom} /></label>
      <label class="rc-lbl">To<input type="date" id="rc-to" value={customTo} /></label>
      <button type="button" id="rc-apply" class="rc-apply">Apply range</button>
    </div>
  </div>
  <nav class="px-2 overflow-y-auto flex-1">
    <div class="text-[10.5px] tracking-wider uppercase px-2.5 pt-3 pb-1.5 font-semibold rail-hide" style="color:var(--text-faint);">Library</div>
    <a href="/?mode=recent" class="lib-item" data-active={mode === "recent"} title="Recent"><span class="ico">◷</span><span class="lbl-t">Recent</span></a>
    <a href="/?mode=all" class="lib-item" data-active={mode === "all"} title="All sessions"><span class="ico">≡</span><span class="lbl-t">All sessions</span> <span class="ml-auto text-[11px] rail-hide">{tree.totalCount}</span></a>
    <a href="/graph" class="lib-item" title="Graph view"><span class="ico">⌗</span><span class="lbl-t">Graph view</span></a>
    <a href="/ask" class="lib-item" title="Ask history"><span class="ico">✦</span><span class="lbl-t">Ask history</span></a>
    <a href="/live" class="lib-item" title="Running sessions"><span class="ico">◉</span><span class="lbl-t">Live</span> <span id="live-nav-count" class="ml-auto text-[11px] rail-hide" style="color:var(--c-green); display:none;"></span></a>

    <div class="px-2.5 pt-3 pb-1 rail-hide" id="title-tools">
      <span class="text-[10.5px] tracking-wider uppercase font-semibold" style="color:var(--text-faint);">Session titles</span>
      <div class="flex items-center gap-2 mt-1.5">
        <button id="smart-name" class="title-act" disabled={nameRunning} data-busy={nameRunning ? "1" : undefined} title="Generate AI titles for sessions that don't have a good one yet"><span class="ai-spin" aria-hidden="true"></span><span class="ai-lbl">{nameRunning ? "✨ Naming…" : "✨ Smart-name"}</span></button>
        <button id="force-name" class="title-act" disabled={nameRunning} data-busy={nameRunning ? "1" : undefined} title="Regenerate AI titles for ALL sessions (overwrites existing — costs more)"><span class="ai-spin" aria-hidden="true"></span><span class="ai-lbl">{nameRunning ? "Naming…" : "Re-name all"}</span></button>
      </div>
      <div id="name-note" class="text-[11px] mt-1" style="display:none;color:var(--text-faint);"></div>
    </div>

    <div id="running-now" class="rail-hide" style="display:none;">
      <div class="text-[10.5px] tracking-wider uppercase px-2.5 pt-3.5 pb-1.5 font-semibold" style="color:var(--text-faint);">
        Running now <span id="running-now-count"></span>
      </div>
      <div id="running-now-list"></div>
    </div>

    <div class="rail-hide">
    <div class="flex items-center px-2.5 pt-3.5 pb-1.5">
      <span class="text-[10.5px] tracking-wider uppercase font-semibold" style="color:var(--text-faint);">Topics</span>
      <button id="cluster-topics" class="ml-auto" disabled={clusterRunning} data-busy={clusterRunning ? "1" : undefined} style="background:none;border:none;color:var(--amber-bright);cursor:pointer;font-size:10.5px;" title="Cluster new (unclustered) sessions into topics with AI"><span class="cluster-spinner" aria-hidden="true"></span><span class="cluster-label">✨ {clusterRunning ? "Clustering…" : (topics.length ? "Cluster new" : "Cluster")}</span></button>
    </div>
    <div id="cluster-note" class="px-2.5 pb-1 text-[11px]" style="display:none;color:var(--text-faint);">~3 min &amp; ~$0.08 — keep this tab open.</div>
    {topics.length === 0 && (
      <div class="px-2.5 pb-1 text-[11.5px]" style="color:var(--text-faint);">Click ✨ to group sessions by topic.</div>
    )}
    {topics.map((tp) => (
      <a href={`/?topic=${tp.id}`} class="lib-item" data-active={tp.id === activeTopic}>
        <span class="w-2 h-2 rounded-full inline-block" style="background:var(--amber);"></span>
        <span class="truncate">{tp.name}</span>
        <span class="ml-auto text-[11px] ct">{tp.sessionCount}</span>
        <button class="topic-act topic-rename" title="Rename topic — rename to an existing topic's name to merge them" data-id={tp.id} data-name={tp.name}>✎</button>
        <button class="topic-act topic-del" title="Delete topic (sessions stay indexed, just un-grouped)" data-id={tp.id} data-name={tp.name}>✕</button>
      </a>
    ))}

    <div class="text-[10.5px] tracking-wider uppercase px-2.5 pt-3.5 pb-1.5 font-semibold" style="color:var(--text-faint);">Repositories</div>
    {tree.repos.map((repo) => (
      <div class="repo-group" data-repo={repo.repoId} data-open={repo.repoId === activeRepo}>
        <a href={`/?repo=${encodeURIComponent(repo.repoId)}`} class="lib-item" data-active={repo.repoId === activeRepo}>
          <button class="caret" aria-label="toggle">›</button>
          <span class="w-2 h-2 rounded-full inline-block" style="background:var(--c-green);"></span>
          <span class="truncate">{repo.displayName}</span>
          <span class="ml-auto text-[11px] ct">{repo.sessionCount}</span>
          <button class="hide-btn" title={`Hide ${repo.displayName} from all views`} data-hide={JSON.stringify(repo.workdirs.map((w) => w.path))}>✕</button>
        </a>
        <div class="children">
          {repo.workdirs.map((w) => (
            <a href={`/?workdir=${encodeURIComponent(w.path)}`}
               class="lib-item child" data-active={w.path === activeWorkdir} style={w.existsOnDisk ? "" : "opacity:.5;"}>
              <span class="w-1.5 h-1.5 rounded-full inline-block" style={`background:${w.existsOnDisk ? "var(--violet)" : "var(--text-faint)"};`}></span>
              <span class="truncate">{w.label}{w.existsOnDisk ? "" : " · deleted"}</span>
              <span class="ml-auto text-[11px] ct">{w.sessionCount}</span>
              <button class="hide-btn" title={`Hide ${w.label}`} data-hide={JSON.stringify([w.path])}>✕</button>
            </a>
          ))}
        </div>
      </div>
    ))}
    </div>
  </nav>
  <div class="flex items-center gap-3 px-4 py-2.5 text-[12.5px] rail-hide" style="border-top:1px solid var(--border-soft); color:var(--text-dim);">
    <a href="/projects" style="color:var(--text-dim); text-decoration:none;" title="Manage hidden directories">⌫ Hidden</a>
    <button id="theme-toggle" class="ml-auto" style="background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:12.5px;" title="Toggle theme">☾ Theme</button>
  </div>
</div>

<script>
  // Theme toggle: flip the warm light/dark variant and persist it.
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const light = document.documentElement.classList.toggle("theme-light");
    try { localStorage.setItem("ccaudit-theme", light ? "light" : "dark"); } catch {}
  });

  // Global date-range filter: persist in a cookie the server reads, then reload in place.
  const setRange = (v: string) => {
    document.cookie = `ccaudit-range=${v}; path=/; max-age=31536000; samesite=lax`;
    location.reload();
  };
  const customPanel = document.getElementById("range-custom");
  document.querySelectorAll("#range-ctl .rbtn").forEach((b) =>
    b.addEventListener("click", () => {
      const v = (b as HTMLElement).dataset.range || "all";
      if (v === "custom") { customPanel?.toggleAttribute("hidden"); return; } // reveal the date pickers
      setRange(v);
    }));
  document.getElementById("rc-apply")?.addEventListener("click", () => {
    const from = (document.getElementById("rc-from") as HTMLInputElement)?.value;
    const to = (document.getElementById("rc-to") as HTMLInputElement)?.value;
    if (!from || !to) return;
    const fromMs = new Date(from + "T00:00:00").getTime();
    const toMs = new Date(to + "T23:59:59.999").getTime();
    if (Number.isNaN(fromMs) || Number.isNaN(toMs) || toMs < fromMs) return;
    setRange(`custom:${fromMs}:${toMs}`);
  });
</script>

<style>
  .range-row { display:flex; gap:4px; }
  .rbtn { flex:1; font-size:11.5px; padding:3px 0; text-align:center; border-radius:7px; background:var(--canvas); border:1px solid var(--border); color:var(--text-dim); cursor:pointer; }
  .rbtn:hover { color:var(--text); }
  .rbtn[data-on="true"] { background:var(--amber); color:#241f17; border-color:var(--amber); font-weight:600; }
  .range-custom { display:flex; flex-direction:column; gap:8px; margin-top:8px; padding:10px; background:var(--canvas); border:1px solid var(--border); border-radius:9px; }
  .range-custom[hidden] { display:none; }
  .rc-lbl { display:flex; flex-direction:column; gap:3px; font-size:9.5px; text-transform:uppercase; letter-spacing:.07em; color:var(--text-faint); }
  .rc-lbl input { width:100%; box-sizing:border-box; background:var(--panel); border:1px solid var(--border); border-radius:6px; color:var(--text); font-size:12.5px; font-family:var(--mono); padding:5px 8px; color-scheme:dark; }
  .rc-lbl input:focus { outline:none; border-color:var(--amber); }
  .rc-lbl input::-webkit-calendar-picker-indicator { filter:invert(.65) sepia(1) saturate(2) hue-rotate(2deg); cursor:pointer; }
  .rc-apply { font-size:11.5px; padding:5px 0; margin-top:2px; border-radius:7px; background:var(--amber); color:#241f17; font-weight:600; border:1px solid var(--amber); cursor:pointer; }
  .rc-apply:hover { background:var(--amber); color:#241f17; border-color:var(--amber); }
  /* Icon rail (html.nav-rail): hide labels/sections, center the glyphs. */
  .rail-toggle { background:none; border:none; color:var(--text-faint); cursor:pointer; font-size:14px; line-height:1; padding:2px 5px; border-radius:6px; }
  .rail-toggle::before { content:"«"; }
  .rail-toggle:hover { color:var(--text); background:var(--panel-2); }
  /* Gemini-style collapse: in the rail there is ONE control — the logo. Hovering it reveals an
     expand button (the logo swaps to a →| glyph); the persistent collapse button is hidden so the
     two toggles never stack/overlap. */
  .brand-logo { position:relative; display:inline-flex; align-items:center; justify-content:center; width:24px; height:24px; background:none; border:none; padding:0; cursor:default; }
  .brand-logo .expand-ico { position:absolute; inset:-3px; display:none; align-items:center; justify-content:center; border-radius:7px; background:var(--panel); border:1px solid var(--border); color:var(--text-dim); font-size:12px; }
  :global(html.nav-rail) #rail-toggle { display:none; }
  :global(html.nav-rail) .brand-row { justify-content:center; }
  :global(html.nav-rail) .brand-logo { cursor:pointer; }
  :global(html.nav-rail) .brand-logo:hover img { opacity:0; }
  :global(html.nav-rail) .brand-logo:hover .expand-ico { display:flex; }
  .lib-item .ico { width:18px; text-align:center; flex:none; }
  :global(html.nav-rail) .rail-hide, :global(html.nav-rail) .lbl-t { display:none !important; }
  :global(html.nav-rail) .lib-item { justify-content:center; gap:0; padding:9px 0; }
  :global(html.nav-rail) .lib-item .ico { width:auto; font-size:16px; }
  :global(html.nav-rail) [data-open-cmdk] { justify-content:center; }
  :global(html.nav-rail) .rail-toggle { margin:0 auto; }
  /* Long-running AI actions (cluster / name): a visible spinner that appears while busy, so the
     button never looks dead and users don't re-tap it. */
  .cluster-spinner, .ai-spin { display:none; width:9px; height:9px; margin-right:5px; vertical-align:-1px;
    border:1.5px solid var(--border); border-top-color:var(--amber-bright); border-radius:50%; animation:ccspin .7s linear infinite; }
  button[data-busy="1"] .cluster-spinner, button[data-busy="1"] .ai-spin { display:inline-block; }
  @keyframes ccspin { to { transform:rotate(360deg); } }
  .title-act { display:inline-flex; align-items:center; background:var(--canvas); border:1px solid var(--border); color:var(--text-dim); font-size:11px; padding:3px 8px; border-radius:6px; cursor:pointer; }
  .title-act:hover { color:var(--text); border-color:var(--amber); }
  .title-act[data-busy="1"] { opacity:.75; cursor:default; }
  .lib-item { display:flex; align-items:center; gap:9px; padding:6px 10px; border-radius:7px; cursor:pointer; white-space:nowrap; font-size:14px; color:var(--text-dim); text-decoration:none; }
  .lib-item:hover { background:var(--panel-2); color:var(--text); }
  .lib-item[data-active="true"] { background:var(--raise); color:var(--text); }
  /* The Running-now items are injected via innerHTML (no Astro scope attribute), so the scoped
     .lib-item rule above never reaches them — style them with a global rule, scoped under the list. */
  #running-now-list :global(.lib-item) { display:flex; align-items:center; gap:9px; padding:6px 10px; border-radius:7px; white-space:nowrap; font-size:13.5px; color:var(--text-dim); text-decoration:none; }
  #running-now-list :global(.lib-item:hover) { background:var(--panel-2); color:var(--text); }
  #running-now-list :global(.truncate) { overflow:hidden; text-overflow:ellipsis; min-width:0; }
  .lib-item.child { padding-left:30px; font-size:13px; }
  .caret { background:none; border:none; color:var(--text-faint); width:10px; cursor:pointer; transition:transform .15s; padding:0; }
  .repo-group[data-open="true"] .caret { transform:rotate(90deg); }
  .children { display:none; }
  .repo-group[data-open="true"] .children { display:block; }
  /* Always present (keyboard-focusable, touch-reachable) but low-emphasis at rest. */
  .hide-btn { opacity:.35; background:none; border:none; color:var(--text-faint); cursor:pointer; font-size:11px; padding:0 2px; margin-left:6px; transition:opacity .12s, color .12s; }
  .hide-btn:hover { color:var(--c-orange); opacity:1; }
  .lib-item:hover .hide-btn, .lib-item:focus-within .hide-btn { opacity:1; }
  .hide-btn:focus-visible { opacity:1; outline:1px solid var(--amber-bright); outline-offset:1px; border-radius:4px; }
  .hide-btn[disabled] { cursor:default; opacity:.5; }
  .topic-act { opacity:0; background:none; border:none; color:var(--text-faint); cursor:pointer; font-size:11px; padding:0 2px; margin-left:5px; transition:opacity .12s, color .12s; }
  .topic-act.topic-del:hover { color:var(--c-orange); opacity:1; }
  .topic-act.topic-rename:hover { color:var(--amber-bright); opacity:1; }
  .lib-item:hover .topic-act, .lib-item:focus-within .topic-act { opacity:.5; }
  .lib-item:hover .topic-act:hover { opacity:1; }
  .topic-act:focus-visible { opacity:1; outline:1px solid var(--amber-bright); outline-offset:1px; border-radius:4px; }
  .topic-act[disabled] { cursor:default; opacity:.4; }
  /* Thin top-of-viewport progress bar shown the instant a destructive action fires. */
  #topbar-progress { position:fixed; top:0; left:0; height:2px; width:0; z-index:60; background:linear-gradient(90deg,var(--amber),var(--c-orange)); opacity:0; pointer-events:none; transition:width .3s ease, opacity .2s; }
  #topbar-progress.active { opacity:1; width:88%; transition:width 8s cubic-bezier(.1,.7,.2,1), opacity .15s; }
</style>

<script>
  // Repo expand/collapse — persisted across navigation (full page reloads) in localStorage,
  // so opening a repo and clicking into one of its sessions keeps the repo open.
  const OPEN_KEY = "ccaudit-open-repos";
  const openSet = new Set<string>((() => { try { return JSON.parse(localStorage.getItem(OPEN_KEY) || "[]"); } catch { return []; } })());
  // Restore on load (the active repo is already open server-side; merge the rest).
  document.querySelectorAll<HTMLElement>(".repo-group").forEach((g) => {
    if (g.dataset.repo && openSet.has(g.dataset.repo)) g.dataset.open = "true";
  });
  document.querySelectorAll(".caret").forEach((c) => {
    c.addEventListener("click", (e) => {
      e.preventDefault(); e.stopPropagation();
      const group = (e.currentTarget as HTMLElement).closest(".repo-group") as HTMLElement;
      const open = group.dataset.open !== "true";
      group.dataset.open = open ? "true" : "false";
      const id = group.dataset.repo;
      if (id) { open ? openSet.add(id) : openSet.delete(id); try { localStorage.setItem(OPEN_KEY, JSON.stringify([...openSet])); } catch {} }
    });
  });

  // Long-running AI actions (cluster / smart-name / re-name-all): one helper that disables the
  // button, shows a spinner + progress bar + note, ignores repeat taps, and reloads on success.
  function runAiAction(btn: HTMLButtonElement | null, o: { url: string; body: object; workingLabel: string; note: string; confirm?: string; idleNote?: string; noteEl: HTMLElement | null }) {
    if (!btn || btn.dataset.busy === "1") return;
    if (o.confirm && !window.confirm(o.confirm)) return;
    btn.dataset.busy = "1"; btn.disabled = true;
    const lbl = btn.querySelector(".ai-lbl") || btn.querySelector(".cluster-label");
    const orig = lbl ? lbl.textContent : null;
    if (lbl && o.workingLabel) lbl.textContent = o.workingLabel;
    startProgress();
    if (o.noteEl) { o.noteEl.textContent = o.note; o.noteEl.style.color = "var(--text-faint)"; o.noteEl.style.display = ""; }
    fetch(o.url, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(o.body) })
      .then(async (res) => {
        const j = await res.json().catch(() => ({})) as { error?: string; named?: number; newlyClustered?: number };
        if (res.ok) {
          const changed = (j.named ?? 0) > 0 || (j.newlyClustered ?? 0) > 0;
          if (changed) { window.location.href = "/"; return; } // refresh to show new titles/topics
          // Nothing to do (e.g. every session already has a title) — restore + inform, don't reload.
          btn.dataset.busy = ""; btn.disabled = false;
          if (lbl && orig != null) lbl.textContent = orig;
          stopProgress();
          if (o.noteEl) { o.noteEl.textContent = o.idleNote || "Nothing to do."; o.noteEl.style.color = "var(--text-faint)"; o.noteEl.style.display = ""; }
          return;
        }
        throw new Error(j.error || ("HTTP " + res.status));
      })
      .catch((err) => {
        btn.dataset.busy = ""; btn.disabled = false;
        if (lbl && orig != null) lbl.textContent = orig;
        stopProgress();
        if (o.noteEl) { o.noteEl.textContent = "Failed: " + err.message; o.noteEl.style.color = "#d77"; o.noteEl.style.display = ""; }
      });
  }
  (document.getElementById("cluster-topics") as HTMLButtonElement | null)?.addEventListener("click", (e) => {
    e.preventDefault(); e.stopPropagation();
    runAiAction(e.currentTarget as HTMLButtonElement, { url: "/api/cluster", body: {}, workingLabel: "✨ Clustering…", note: "Clustering sessions into topics… ~1–3 min & a few cents — keep this tab open.", idleNote: "No new sessions to cluster.", noteEl: document.getElementById("cluster-note") });
  });
  (document.getElementById("smart-name") as HTMLButtonElement | null)?.addEventListener("click", (e) =>
    runAiAction(e.currentTarget as HTMLButtonElement, { url: "/api/name", body: { action: "smart" }, workingLabel: "✨ Naming…", note: "Generating titles for untitled sessions… keep this tab open.", idleNote: "All sessions already have titles — use “Re-name all” to regenerate.", noteEl: document.getElementById("name-note") }));
  (document.getElementById("force-name") as HTMLButtonElement | null)?.addEventListener("click", (e) =>
    runAiAction(e.currentTarget as HTMLButtonElement, { url: "/api/name", body: { action: "force" }, workingLabel: "Naming all…", confirm: "Regenerate AI titles for ALL sessions? This overwrites existing titles and costs a few cents.", note: "Re-titling every session… can take a few minutes — keep this tab open.", noteEl: document.getElementById("name-note") }));

  // Shared thin top progress bar — immediate feedback before a navigating action.
  const progressEl = document.getElementById("topbar-progress");
  function startProgress() { progressEl?.classList.add("active"); }
  function stopProgress() { progressEl?.classList.remove("active"); }

  // Hide a repo (all its workdirs) or a single workdir from every view.
  let hideInFlight = false;
  document.querySelectorAll(".hide-btn").forEach((b) => {
    b.addEventListener("click", async (e) => {
      e.preventDefault(); e.stopPropagation();
      if (hideInFlight) return; // guard against double-clicks across all hide buttons
      const el = e.currentTarget as HTMLButtonElement;
      let prefixes: string[] = [];
      try { prefixes = JSON.parse(el.dataset.hide || "[]"); } catch {}
      if (!prefixes.length) return;
      hideInFlight = true;
      el.disabled = true;
      startProgress();
      try {
        const res = await fetch("/api/exclusions", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ action: "add", prefixes }),
        });
        if (res.ok) { window.location.href = "/"; }
        else { hideInFlight = false; el.disabled = false; stopProgress(); }
      } catch { hideInFlight = false; el.disabled = false; stopProgress(); }
    });
  });

  // Topic management: rename (rename to an existing name = merge) + delete.
  let topicInFlight = false;
  async function mutateTopic(method: string, payload: Record<string, unknown>, btn: HTMLButtonElement) {
    if (topicInFlight) return;
    topicInFlight = true; btn.disabled = true; startProgress();
    try {
      const res = await fetch("/api/topics", { method, headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
      if (res.ok) { window.location.reload(); return; }
      const d = await res.json().catch(() => ({}));
      alert((d && d.error) || "Action failed");
    } catch (err) { alert("Action failed: " + (err && (err as Error).message)); }
    topicInFlight = false; btn.disabled = false; stopProgress();
  }
  document.querySelectorAll(".topic-rename").forEach((b) => {
    b.addEventListener("click", (e) => {
      e.preventDefault(); e.stopPropagation();
      const el = e.currentTarget as HTMLButtonElement;
      const cur = el.dataset.name || "";
      const name = prompt("Rename topic (use an existing topic's exact name to merge them):", cur);
      if (name == null) return;
      const trimmed = name.trim();
      if (!trimmed || trimmed === cur) return;
      mutateTopic("PATCH", { id: Number(el.dataset.id), name: trimmed }, el);
    });
  });
  document.querySelectorAll(".topic-del").forEach((b) => {
    b.addEventListener("click", (e) => {
      e.preventDefault(); e.stopPropagation();
      const el = e.currentTarget as HTMLButtonElement;
      if (!confirm(`Delete topic "${el.dataset.name}"? Its sessions stay indexed — they just become un-grouped.`)) return;
      mutateTopic("DELETE", { id: Number(el.dataset.id) }, el);
    });
  });
</script>

<script>
  // Light poll of /api/live to keep the sidebar "Running now" list current while a page is open.
  function shortId(s: string) { return s.slice(0, 8); }
  async function refreshRunning() {
    let data: { running: Array<{ sessionId: string; name: string | null; cwd: string | null; isIndexed: boolean }>; jobs?: string[] };
    try { const res = await fetch("/api/live"); if (!res.ok) return; data = await res.json(); }
    catch { return; }
    syncJobs(data.jobs ?? []);
    const running = data.running ?? [];
    const section = document.getElementById("running-now");
    const list = document.getElementById("running-now-list");
    const count = document.getElementById("running-now-count");
    const navCount = document.getElementById("live-nav-count");
    if (navCount) { navCount.textContent = running.length ? `● ${running.length}` : ""; navCount.style.display = running.length ? "" : "none"; }
    if (!section || !list || !count) return;
    if (running.length === 0) { section.style.display = "none"; list.innerHTML = ""; return; }
    section.style.display = "";
    count.textContent = `(${running.length})`;
    list.innerHTML = running.map((r) => {
      const label = (r.name || shortId(r.sessionId)).replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c] as string));
      const href = r.isIndexed ? `/s/${r.sessionId}` : "/live";
      return `<a href="${href}" class="lib-item" title="${label}"><span class="w-2 h-2 rounded-full inline-block" style="background:var(--c-green);"></span><span class="truncate">${label}</span></a>`;
    }).join("");
  }
  // Reflect process-wide AI jobs live: mark buttons busy when a run starts (e.g. from another tab),
  // and reload when one finishes so this page shows the fresh titles/topics + re-enabled buttons.
  function syncJobs(jobs: string[]) {
    ([["cluster", "cluster-topics", "✨ Clustering…"], ["name", "smart-name", "✨ Naming…"], ["name", "force-name", "Naming…"]] as const).forEach(([kind, id, working]) => {
      const btn = document.getElementById(id) as HTMLButtonElement | null;
      if (!btn) return;
      const running = jobs.indexOf(kind) !== -1;
      const was = btn.dataset.busy === "1";
      if (running && !was) {
        btn.dataset.busy = "1"; btn.disabled = true;
        const lbl = btn.querySelector(".ai-lbl") || btn.querySelector(".cluster-label");
        if (lbl) lbl.textContent = working;
      } else if (!running && was) {
        window.location.reload(); // finished elsewhere → refresh to show results
      }
    });
  }
  refreshRunning();
  setInterval(refreshRunning, 15000);
</script>
