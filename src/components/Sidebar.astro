---
// src/components/Sidebar.astro
import type { LibraryTree } from "../db/library";
import type { TopicSummary } from "../db/topics";
interface Props { tree: LibraryTree; topics?: TopicSummary[]; activeRepo?: string; activeWorkdir?: string; activeTopic?: number; mode?: string; }
const { tree, topics = [], activeRepo, activeWorkdir, activeTopic, mode } = Astro.props;
---
<div id="topbar-progress" aria-hidden="true"></div>
<div class="flex flex-col h-full" style="color:var(--text-dim);">
  <div class="flex items-center gap-2 px-4 pt-4 pb-3">
    <div class="w-[22px] h-[22px] rounded-md grid place-items-center font-bold text-[13px]"
         style="background:linear-gradient(135deg,var(--amber),var(--c-orange)); color:#241f17;">c</div>
    <h1 class="font-serif text-[18px] font-semibold" style="color:var(--text);">ccaudit</h1>
  </div>
  <a href="/search" data-open-cmdk class="mx-3 mb-3 flex items-center gap-2 px-2.5 py-1.5 rounded-lg text-[13px]"
     style="background:var(--canvas); border:1px solid var(--border); color:var(--text-faint); text-decoration:none; cursor:pointer;">
    <span>⚲</span><span>Search history…</span>
    <span class="ml-auto font-mono-w text-[11px] px-1.5 rounded" style="background:var(--raise); border:1px solid var(--border);">⌘K</span>
  </a>
  <nav class="px-2 overflow-y-auto flex-1">
    <div class="text-[10.5px] tracking-wider uppercase px-2.5 pt-3 pb-1.5 font-semibold" style="color:var(--text-faint);">Library</div>
    <a href="/?mode=recent" class="lib-item" data-active={mode === "recent"}>◷ Recent</a>
    <a href="/?mode=all" class="lib-item" data-active={mode === "all"}>✦ All sessions <span class="ml-auto text-[11px]">{tree.totalCount}</span></a>
    <a href="/graph?view=repos" class="lib-item">⌗ Graph view</a>
    <a href="/ask" class="lib-item">◈ Ask history</a>

    <div class="flex items-center px-2.5 pt-3.5 pb-1.5">
      <span class="text-[10.5px] tracking-wider uppercase font-semibold" style="color:var(--text-faint);">Topics</span>
      <button id="cluster-topics" class="ml-auto" style="background:none;border:none;color:var(--amber-bright);cursor:pointer;font-size:10.5px;" title="Cluster new (unclustered) sessions into topics with AI"><span class="cluster-spinner" aria-hidden="true"></span><span class="cluster-label">✨ {topics.length ? "Cluster new" : "Cluster"}</span></button>
    </div>
    <div id="cluster-note" class="px-2.5 pb-1 text-[11px]" style="display:none;color:var(--text-faint);">~3 min &amp; ~$0.08 — keep this tab open.</div>
    {topics.length === 0 && (
      <div class="px-2.5 pb-1 text-[11.5px]" style="color:var(--text-faint);">Click ✨ to group sessions by topic.</div>
    )}
    {topics.map((tp) => (
      <a href={`/?topic=${tp.id}`} class="lib-item" data-active={tp.id === activeTopic}>
        <span class="w-2 h-2 rounded-full inline-block" style="background:var(--amber);"></span>
        <span class="truncate">{tp.name}</span>
        <span class="ml-auto text-[11px] ct">{tp.sessionCount}</span>
        <button class="topic-act topic-rename" title="Rename topic — rename to an existing topic's name to merge them" data-id={tp.id} data-name={tp.name}>✎</button>
        <button class="topic-act topic-del" title="Delete topic (sessions stay indexed, just un-grouped)" data-id={tp.id} data-name={tp.name}>✕</button>
      </a>
    ))}

    <div class="text-[10.5px] tracking-wider uppercase px-2.5 pt-3.5 pb-1.5 font-semibold" style="color:var(--text-faint);">Repositories</div>
    {tree.repos.map((repo) => (
      <div class="repo-group" data-open={repo.repoId === activeRepo}>
        <a href={`/?repo=${encodeURIComponent(repo.repoId)}`} class="lib-item" data-active={repo.repoId === activeRepo}>
          <button class="caret" aria-label="toggle">›</button>
          <span class="w-2 h-2 rounded-full inline-block" style="background:var(--c-green);"></span>
          <span class="truncate">{repo.displayName}</span>
          <span class="ml-auto text-[11px] ct">{repo.sessionCount}</span>
          <button class="hide-btn" title={`Hide ${repo.displayName} from all views`} data-hide={JSON.stringify(repo.workdirs.map((w) => w.path))}>✕</button>
        </a>
        <div class="children">
          {repo.workdirs.map((w) => (
            <a href={`/?workdir=${encodeURIComponent(w.path)}`}
               class="lib-item child" data-active={w.path === activeWorkdir} style={w.existsOnDisk ? "" : "opacity:.5;"}>
              <span class="w-1.5 h-1.5 rounded-full inline-block" style={`background:${w.existsOnDisk ? "var(--violet)" : "var(--text-faint)"};`}></span>
              <span class="truncate">{w.label}{w.existsOnDisk ? "" : " · deleted"}</span>
              <span class="ml-auto text-[11px] ct">{w.sessionCount}</span>
              <button class="hide-btn" title={`Hide ${w.label}`} data-hide={JSON.stringify([w.path])}>✕</button>
            </a>
          ))}
        </div>
      </div>
    ))}
  </nav>
  <div class="flex items-center gap-3 px-4 py-2.5 text-[12.5px]" style="border-top:1px solid var(--border-soft); color:var(--text-dim);">
    <a href="/projects" style="color:var(--text-dim); text-decoration:none;" title="Manage hidden directories">⌫ Hidden</a>
    <button id="theme-toggle" class="ml-auto" style="background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:12.5px;" title="Toggle theme">☾ Theme</button>
  </div>
</div>

<script>
  // Theme toggle: flip the warm light/dark variant and persist it.
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const light = document.documentElement.classList.toggle("theme-light");
    try { localStorage.setItem("ccaudit-theme", light ? "light" : "dark"); } catch {}
  });
</script>

<style>
  .lib-item { display:flex; align-items:center; gap:9px; padding:6px 10px; border-radius:7px; cursor:pointer; white-space:nowrap; font-size:14px; color:var(--text-dim); text-decoration:none; }
  .lib-item:hover { background:var(--panel-2); color:var(--text); }
  .lib-item[data-active="true"] { background:var(--raise); color:var(--text); }
  .lib-item.child { padding-left:30px; font-size:13px; }
  .caret { background:none; border:none; color:var(--text-faint); width:10px; cursor:pointer; transition:transform .15s; padding:0; }
  .repo-group[data-open="true"] .caret { transform:rotate(90deg); }
  .children { display:none; }
  .repo-group[data-open="true"] .children { display:block; }
  /* Always present (keyboard-focusable, touch-reachable) but low-emphasis at rest. */
  .hide-btn { opacity:.35; background:none; border:none; color:var(--text-faint); cursor:pointer; font-size:11px; padding:0 2px; margin-left:6px; transition:opacity .12s, color .12s; }
  .hide-btn:hover { color:var(--c-orange); opacity:1; }
  .lib-item:hover .hide-btn, .lib-item:focus-within .hide-btn { opacity:1; }
  .hide-btn:focus-visible { opacity:1; outline:1px solid var(--amber-bright); outline-offset:1px; border-radius:4px; }
  .hide-btn[disabled] { cursor:default; opacity:.5; }
  .topic-act { opacity:0; background:none; border:none; color:var(--text-faint); cursor:pointer; font-size:11px; padding:0 2px; margin-left:5px; transition:opacity .12s, color .12s; }
  .topic-act.topic-del:hover { color:var(--c-orange); opacity:1; }
  .topic-act.topic-rename:hover { color:var(--amber-bright); opacity:1; }
  .lib-item:hover .topic-act, .lib-item:focus-within .topic-act { opacity:.5; }
  .lib-item:hover .topic-act:hover { opacity:1; }
  .topic-act:focus-visible { opacity:1; outline:1px solid var(--amber-bright); outline-offset:1px; border-radius:4px; }
  .topic-act[disabled] { cursor:default; opacity:.4; }
  /* Thin top-of-viewport progress bar shown the instant a destructive action fires. */
  #topbar-progress { position:fixed; top:0; left:0; height:2px; width:0; z-index:60; background:linear-gradient(90deg,var(--amber),var(--c-orange)); opacity:0; pointer-events:none; transition:width .3s ease, opacity .2s; }
  #topbar-progress.active { opacity:1; width:88%; transition:width 8s cubic-bezier(.1,.7,.2,1), opacity .15s; }
</style>

<script>
  // Collapse/expand without navigating when the caret is clicked.
  document.querySelectorAll(".caret").forEach((c) => {
    c.addEventListener("click", (e) => {
      e.preventDefault(); e.stopPropagation();
      const group = (e.currentTarget as HTMLElement).closest(".repo-group") as HTMLElement;
      group.dataset.open = group.dataset.open === "true" ? "false" : "true";
    });
  });

  // Cluster all sessions into topics with AI (~3 min, ~$0.08).
  const clusterBtn = document.getElementById("cluster-topics");
  if (clusterBtn) {
    clusterBtn.addEventListener("click", async (e) => {
      e.preventDefault(); e.stopPropagation();
      const el = e.currentTarget as HTMLButtonElement;
      const original = el.textContent;
      el.disabled = true; el.textContent = "✨ Clustering…";
      try {
        const res = await fetch("/api/cluster", { method: "POST", headers: { "Content-Type": "application/json" }, body: "{}" });
        if (res.ok) window.location.href = "/"; else { el.disabled = false; el.textContent = original; }
      } catch { el.disabled = false; el.textContent = original; }
    });
  }

  // Shared thin top progress bar — immediate feedback before a navigating action.
  const progressEl = document.getElementById("topbar-progress");
  function startProgress() { progressEl?.classList.add("active"); }
  function stopProgress() { progressEl?.classList.remove("active"); }

  // Hide a repo (all its workdirs) or a single workdir from every view.
  let hideInFlight = false;
  document.querySelectorAll(".hide-btn").forEach((b) => {
    b.addEventListener("click", async (e) => {
      e.preventDefault(); e.stopPropagation();
      if (hideInFlight) return; // guard against double-clicks across all hide buttons
      const el = e.currentTarget as HTMLButtonElement;
      let prefixes: string[] = [];
      try { prefixes = JSON.parse(el.dataset.hide || "[]"); } catch {}
      if (!prefixes.length) return;
      hideInFlight = true;
      el.disabled = true;
      startProgress();
      try {
        const res = await fetch("/api/exclusions", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ action: "add", prefixes }),
        });
        if (res.ok) { window.location.href = "/"; }
        else { hideInFlight = false; el.disabled = false; stopProgress(); }
      } catch { hideInFlight = false; el.disabled = false; stopProgress(); }
    });
  });

  // Topic management: rename (rename to an existing name = merge) + delete.
  let topicInFlight = false;
  async function mutateTopic(method: string, payload: Record<string, unknown>, btn: HTMLButtonElement) {
    if (topicInFlight) return;
    topicInFlight = true; btn.disabled = true; startProgress();
    try {
      const res = await fetch("/api/topics", { method, headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
      if (res.ok) { window.location.reload(); return; }
      const d = await res.json().catch(() => ({}));
      alert((d && d.error) || "Action failed");
    } catch (err) { alert("Action failed: " + (err && (err as Error).message)); }
    topicInFlight = false; btn.disabled = false; stopProgress();
  }
  document.querySelectorAll(".topic-rename").forEach((b) => {
    b.addEventListener("click", (e) => {
      e.preventDefault(); e.stopPropagation();
      const el = e.currentTarget as HTMLButtonElement;
      const cur = el.dataset.name || "";
      const name = prompt("Rename topic (use an existing topic's exact name to merge them):", cur);
      if (name == null) return;
      const trimmed = name.trim();
      if (!trimmed || trimmed === cur) return;
      mutateTopic("PATCH", { id: Number(el.dataset.id), name: trimmed }, el);
    });
  });
  document.querySelectorAll(".topic-del").forEach((b) => {
    b.addEventListener("click", (e) => {
      e.preventDefault(); e.stopPropagation();
      const el = e.currentTarget as HTMLButtonElement;
      if (!confirm(`Delete topic "${el.dataset.name}"? Its sessions stay indexed — they just become un-grouped.`)) return;
      mutateTopic("DELETE", { id: Number(el.dataset.id) }, el);
    });
  });
</script>
