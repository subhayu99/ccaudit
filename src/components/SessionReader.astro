---
// src/components/SessionReader.astro — warm-obsidian in-shell transcript reader.
import { existsSync } from "node:fs";
import { getDb } from "../db/init";
import { getSession } from "../db/sessions";
import { getSessionMessages, getSessionMessagesTail } from "../db/messages";
import { classifyMessage } from "../lib/message-kind";
import { renderMarkdown } from "../lib/markdown";
import { formatTimestamp, truncate, shortSessionId } from "../lib/render";
import { cleanPromptText } from "../lib/clean-prompt";
import { segmentSession } from "../lib/segment";
import { getLabels, spineHash } from "../db/labels";
import { posixQuote } from "../lib/shell";
import { sessionCostUsd, formatUsd, totalTokens } from "../lib/pricing";

interface Props { sessionId: string; }
const { sessionId } = Astro.props;

const db = getDb();
const session = getSession(db, sessionId);
// How many recent visible turns to render. Default 500; "Load earlier" raises it via ?show=.
const showParam = Math.trunc(Number(Astro.url.searchParams.get("show")));
const SHOW = Number.isFinite(showParam) && showParam > 0 ? Math.min(showParam, 20000) : 500;
// Only load what we'll render: the tail for huge sessions (raw includes noise, ~6 raw msgs per
// visible turn). Load all once the requested window would cover the whole session.
const RAW_TAIL = Math.max(2500, SHOW * 6);
const tailLoaded = !!session && session.messageCount > RAW_TAIL;
const messages = !session
  ? []
  : tailLoaded
    ? getSessionMessagesTail(db, sessionId, RAW_TAIL)
    : getSessionMessages(db, sessionId);

// Deterministic segments + any cached AI labels (while the db is still open).
const segments = segmentSession(messages);
const cachedLabels = getLabels(db, sessionId);
const labelsFresh = !!cachedLabels && cachedLabels.spineHash === spineHash(segments);
const segLabel = (i: number): string | null => (labelsFresh ? cachedLabels!.labels[i] ?? null : null);

const classified = messages.map((m) => ({ m, kind: classifyMessage(m) }));
const allVisible = classified.filter((c) => c.kind !== "noise");

// Cap rendered turns so a 17k-message session doesn't ship a multi-MB page.
// Keep the most recent turns (resume-relevant); the title preserves the ask.
const CAP = SHOW;
const truncatedBy = Math.max(0, allVisible.length - CAP);
const visible = truncatedBy > 0 ? allVisible.slice(allVisible.length - CAP) : allVisible;

// There's earlier history to load if we capped the visible turns OR cut the raw tail.
const hasEarlier = truncatedBy > 0 || tailLoaded;
const firstShownLine = visible.length ? visible[0]!.m.lineNo : null;
// "Load earlier" preserves the current URL (session/repo/topic) and jumps back to the boundary.
const earlierUrl = new URL(Astro.url);
earlierUrl.searchParams.set("show", String(SHOW + 1000));
const earlierHref = `${earlierUrl.pathname}${earlierUrl.search}${firstShownLine !== null ? `#m${firstShownLine}` : ""}`;

// Map each segment's opening line to the segment so we can drop a divider there.
const segByStartLine = new Map(segments.map((s) => [s.startLine, s]));

// Pre-render markdown + tool labels for each visible turn.
type Block =
  | { t: "user" | "assistant"; html: string; lineNo: number; label: string }
  | { t: "tool-use" | "tool-result"; text: string; lineNo: number }
  | { t: "attachment"; text: string; lineNo: number }
  | { t: "compact"; n: number; lineNo: number }
  | { t: "sidechain"; html: string; lineNo: number };

function toolName(rawJson: string): string {
  try {
    const c = JSON.parse(rawJson)?.message?.content;
    if (Array.isArray(c)) {
      const u = c.find((p: { type?: string }) => p?.type === "tool_use");
      if (u?.name) return u.name as string;
      if (c.some((p: { type?: string }) => p?.type === "tool_result")) return "result";
    }
  } catch { /* ignore */ }
  return "tool";
}

let compactN = 0;
const blocks: Block[] = [];
for (const { m, kind } of visible) {
  if (kind === "user-text") blocks.push({ t: "user", html: await renderMarkdown(m.textContent), lineNo: m.lineNo, label: "You" });
  else if (kind === "assistant-text") blocks.push({ t: "assistant", html: await renderMarkdown(m.textContent), lineNo: m.lineNo, label: "Claude" });
  else if (kind === "tool-use") blocks.push({ t: "tool-use", text: toolName(m.rawJson), lineNo: m.lineNo });
  else if (kind === "tool-result") blocks.push({ t: "tool-result", text: truncate(m.textContent ?? "", 280) || "result", lineNo: m.lineNo });
  else if (kind === "attachment") blocks.push({ t: "attachment", text: m.textContent ?? "attachment", lineNo: m.lineNo });
  else if (kind === "compact-summary") { compactN += 1; blocks.push({ t: "compact", n: compactN, lineNo: m.lineNo }); }
  else if (kind === "sidechain") blocks.push({ t: "sidechain", html: await renderMarkdown(m.textContent), lineNo: m.lineNo });
}

const title = session
  ? (session.aiTitle ?? (session.firstPrompt ? cleanPromptText(session.firstPrompt) : "") ?? "").trim() || `Session ${shortSessionId(session.id)}`
  : "";
// Only `cd` into a real, on-disk cwd. session.projectDir is a lossy decode of
// the dir-hash and is not a safe filesystem path, so we never shell out to it.
// POSIX-quote the cwd to prevent shell injection from paths with spaces/quotes.
const resumeCwd = session?.cwd && existsSync(session.cwd) ? session.cwd : null;
const resumeCmd = resumeCwd
  ? `cd ${posixQuote(resumeCwd)}\nclaude --resume ${sessionId}`
  : `claude --resume ${sessionId}  # original cwd unknown`;
const noiseCount = classified.length - visible.length;

// minimap landmarks: user turns + compacts
const landmarks = blocks.filter((b) => b.t === "user" || b.t === "compact");
---
{!session ? (
  <div class="p-8 max-w-[560px]">
    <h2 class="font-serif text-[20px] font-semibold mb-2" style="color:var(--text);">Session not found</h2>
    <p class="text-[13.5px] mb-3" style="color:var(--text-dim);">
      No indexed session with id <span class="font-mono-w" style="color:var(--amber);">{shortSessionId(sessionId)}</span>.
      Its source log may have been removed or renamed since the last index.
    </p>
    <p class="text-[13.5px]" style="color:var(--text-dim);">
      Run <span class="font-mono-w" style="color:var(--text);">ccaudit reindex</span> to refresh, or <a href="/" style="color:var(--amber-bright);">go back to your history</a>.
    </p>
  </div>
) : (
  <div class="reader-wrap">
    <header class="reader-head px-7 pt-6 pb-4" style="border-bottom:1px solid var(--border-soft);">
      <div class="text-[12px] mb-1.5 flex items-center gap-2" style="color:var(--text-faint);">
        <a href="/" style="color:var(--text-faint); text-decoration:none;">← Library</a>
        {session.gitBranch && <><span>·</span><span class="font-mono-w">{session.gitBranch}</span></>}
      </div>
      <h1 class="font-serif text-[24px] font-semibold leading-tight" style="color:var(--text); max-width:62ch;">{title}</h1>
      <div class="flex items-center gap-4 mt-3 text-[12.5px] flex-wrap" style="color:var(--text-dim);">
        <span>{session.messageCount.toLocaleString()} messages</span>
        {session.compactCount > 0 && <span style="color:var(--c-orange);">⊟ {session.compactCount} compacts</span>}
        {session.tokenUsage && <span style="color:var(--amber);" title={`${totalTokens(session.tokenUsage).toLocaleString()} tokens (estimated cost)`}>~{formatUsd(sessionCostUsd(session.tokenUsage))}</span>}
        {noiseCount > 0 && <span style="color:var(--text-faint);">{noiseCount} hidden</span>}
        <span>{formatTimestamp(session.startedAt)} → {formatTimestamp(session.lastActivity)}</span>
        <button id="resume-btn" class="resume">▶ Resume session</button>
      </div>
    </header>

    <div class="convo" id="convo">
      {hasEarlier && (
        <div class="trunc-note">
          <span>⤒ Showing the latest {visible.length.toLocaleString()} turns — earlier history is hidden for performance.</span>
          <a class="load-earlier" href={earlierHref}>⤒ Load 1,000 earlier</a>
        </div>
      )}
      {blocks.map((b) => (
        b.t === "user" || b.t === "assistant" ? (
          <Fragment>
            {segByStartLine.has(b.lineNo) && segByStartLine.get(b.lineNo)!.index > 0 && (
              <div class="seg-divider" id={`seg${segByStartLine.get(b.lineNo)!.index}`}>
                <span class="seg-dot"></span>
                <span class="seg-label">{segLabel(segByStartLine.get(b.lineNo)!.index) ?? segByStartLine.get(b.lineNo)!.opener}</span>
                <span class="seg-meta">{segByStartLine.get(b.lineNo)!.reason === "compact" ? "after compact" : `${segByStartLine.get(b.lineNo)!.gapMinutes}m gap`} · {segByStartLine.get(b.lineNo)!.turnCount} turns</span>
              </div>
            )}
            <div class={`turn ${b.t}`} id={`m${b.lineNo}`}>
              <div class={`role ${b.t}`}>{b.t === "user" ? "● You" : "✦ Claude"}</div>
              <div class="bubble prose-warm" set:html={b.html}></div>
            </div>
          </Fragment>
        ) : b.t === "compact" ? (
          <div class="compact-divider" id={`m${b.lineNo}`}><span>⊟ Compact #{b.n}</span></div>
        ) : b.t === "tool-use" ? (
          <div class="toolchip"><span class="tn">{b.text}</span></div>
        ) : b.t === "tool-result" ? (
          <div class="toolchip result"><span>↳ {b.text}</span></div>
        ) : b.t === "attachment" ? (
          <div class="toolchip"><span>📎 {b.text}</span></div>
        ) : b.t === "sidechain" ? (
          <div class="sidechain prose-warm" set:html={b.html}></div>
        ) : null
      ))}
    </div>

    {segments.length > 1 && (
      <nav class="seg-nav" aria-label="segments">
        <div class="seg-nav-head">
          {segments.length} threads
          {!labelsFresh && <button id="name-threads" class="name-btn" data-session={sessionId}>✨ Name</button>}
        </div>
        {segments.map((s) => (
          <a class="seg-nav-item" href={`#${s.index === 0 ? `m${s.startLine}` : `seg${s.index}`}`}>
            <span class="seg-nav-dot" data-reason={s.reason}></span>
            <span class="seg-nav-text">{segLabel(s.index) ? `✨ ${segLabel(s.index)}` : s.opener}</span>
          </a>
        ))}
      </nav>
    )}

    {landmarks.length > 1 && segments.length <= 1 && (
      <div class="mini">
        {landmarks.map((l) => (
          <a href={`#m${l.lineNo}`} class={`m ${l.t === "compact" ? "c" : "u"}`} title={l.t === "compact" ? "compact" : "user turn"}></a>
        ))}
      </div>
    )}

    <dialog id="resume-dialog" class="resume-dialog">
      <div class="text-[13px] mb-2" style="color:var(--text-dim);">{resumeCwd ? "Run this to resume in the original working directory:" : "Original working directory unknown — run this from your project:"}</div>
      <pre class="resume-pre">{resumeCmd}</pre>
      <div class="flex gap-2 mt-3 justify-end">
        <button id="resume-copy" class="resume-secondary">Copy</button>
        <button id="resume-close" class="resume-secondary">Close</button>
      </div>
    </dialog>
  </div>
)}

<style>
  /* The reader pane (.shell-reader) is the scroll container. The header sticks to its top and
     the thread nav is fixed, so neither scrolls away; JS opens the pane at the bottom. */
  .reader-wrap { position:relative; }
  .reader-head { position:sticky; top:0; z-index:10; background:var(--canvas); }
  .convo { padding:24px 28px 80px; }
  .seg-divider { display:flex; align-items:center; gap:10px; margin:30px 0 20px; padding-top:6px; border-top:1px solid var(--border); max-width:74ch; }
  .seg-dot { width:9px; height:9px; border-radius:50%; background:var(--violet); flex:none; }
  .seg-label { font-family:var(--serif); font-size:15px; color:var(--text); font-weight:600; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .seg-meta { margin-left:auto; font-size:11px; color:var(--text-faint); font-family:var(--mono); white-space:nowrap; }
  /* Collapsed thread index: a slim dot rail pinned to the right edge that expands to full labels
     on hover (grows leftward over the transcript). Click a thread to scroll the chat there. */
  .seg-nav { position:fixed; right:26px; top:118px; width:34px; max-height:calc(100vh - 150px); overflow:hidden; background:var(--panel); border:1px solid var(--border-soft); border-radius:10px; padding:8px 6px; font-size:12px; z-index:20; transition:width .18s ease, box-shadow .18s ease, padding .18s ease; }
  .seg-nav:hover { width:236px; overflow-y:auto; padding:8px; box-shadow:0 14px 40px rgba(0,0,0,.45); }
  .seg-nav-head { font-size:10.5px; text-transform:uppercase; letter-spacing:.1em; color:var(--text-faint); padding:4px 6px 6px; white-space:nowrap; opacity:0; transition:opacity .12s; }
  .seg-nav:hover .seg-nav-head { opacity:1; }
  .seg-nav-item { display:flex; align-items:center; gap:9px; padding:5px 6px; border-radius:6px; color:var(--text-dim); text-decoration:none; }
  .seg-nav-item:hover { background:var(--panel-2); color:var(--text); }
  .seg-nav-dot { width:8px; height:8px; border-radius:50%; flex:none; background:var(--violet); }
  .seg-nav-dot[data-reason="compact"] { background:var(--c-orange); }
  .seg-nav-text { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; opacity:0; transition:opacity .12s; }
  .seg-nav:hover .seg-nav-text { opacity:1; }
  .name-btn { float:right; background:var(--raise); color:var(--amber-bright); border:1px solid var(--border); border-radius:6px; font-size:10.5px; padding:2px 7px; cursor:pointer; }
  .name-btn[disabled] { opacity:.6; cursor:progress; }
  .trunc-note { display:flex; align-items:center; gap:12px; flex-wrap:wrap; background:var(--panel); border:1px dashed var(--border); border-radius:9px; padding:9px 13px; margin-bottom:20px; font-size:12.5px; color:var(--text-faint); max-width:74ch; }
  .load-earlier { margin-left:auto; background:var(--raise); color:var(--amber-bright); border:1px solid var(--border); border-radius:7px; padding:4px 12px; font-size:12px; text-decoration:none; white-space:nowrap; }
  .load-earlier:hover { background:var(--panel-2); }
  /* Anchored jumps (thread nav, deep-links) clear the sticky header. */
  .seg-divider, .compact-divider { scroll-margin-top:124px; }
  .turn { margin-bottom:22px; max-width:74ch; scroll-margin-top:124px; }
  .deep-hit { animation: deepHit 2.4s ease-out; border-radius:8px; }
  @keyframes deepHit {
    0%, 30% { box-shadow:0 0 0 2px var(--amber); background:rgba(210,168,95,.12); }
    100% { box-shadow:0 0 0 0 transparent; background:transparent; }
  }
  .role { font-size:11px; letter-spacing:.08em; text-transform:uppercase; font-weight:700; margin-bottom:7px; }
  .role.user { color:var(--amber); }
  .role.assistant { color:var(--violet); }
  .bubble { border-radius:12px; padding:14px 16px; font-size:14px; line-height:1.6; color:#ddd6c6; background:var(--panel); border:1px solid var(--border-soft); }
  .turn.user .bubble { background:var(--panel-2); border-color:var(--border); }
  .toolchip { display:inline-flex; align-items:center; gap:7px; background:var(--canvas); border:1px solid var(--border-soft); border-radius:8px; padding:6px 11px; font-family:var(--mono); font-size:12px; color:var(--text-dim); margin:0 0 14px; max-width:74ch; overflow:hidden; }
  .toolchip .tn { color:var(--c-green); }
  .toolchip.result { color:var(--text-faint); }
  .compact-divider { display:flex; align-items:center; gap:10px; margin:18px 0 22px; color:var(--c-orange); font-size:12px; font-family:var(--mono); }
  .compact-divider::before, .compact-divider::after { content:""; flex:1; height:1px; background:var(--border); }
  .sidechain { opacity:.7; border-left:2px solid var(--border); padding-left:12px; margin-bottom:18px; max-width:74ch; font-size:13px; }
  .resume { background:linear-gradient(135deg,var(--amber),var(--c-orange)); color:#241f17; font-weight:600; border:none; border-radius:9px; padding:7px 15px; font-size:13px; cursor:pointer; }
  .resume-dialog { background:var(--panel); color:var(--text); border:1px solid var(--border); border-radius:12px; padding:18px 20px; max-width:560px; }
  .resume-dialog::backdrop { background:rgba(0,0,0,.6); }
  .resume-pre { background:#161412; border:1px solid var(--border-soft); border-radius:9px; padding:12px 14px; font-family:var(--mono); font-size:12.5px; color:var(--amber-bright); white-space:pre-wrap; word-break:break-all; }
  .resume-secondary { background:var(--raise); color:var(--text-dim); border:1px solid var(--border); border-radius:7px; padding:5px 12px; font-size:12.5px; cursor:pointer; }
  /* warm markdown */
  .prose-warm :global(p) { margin:0 0 10px; }
  .prose-warm :global(p:last-child) { margin-bottom:0; }
  .prose-warm :global(pre) { background:#161412; border:1px solid var(--border-soft); border-radius:9px; padding:12px 14px; font-family:var(--mono); font-size:12.5px; color:#b9d9b4; overflow-x:auto; white-space:pre-wrap; word-break:break-word; margin:10px 0; }
  .prose-warm :global(code) { font-family:var(--mono); font-size:12.5px; background:var(--canvas); padding:1px 5px; border-radius:4px; color:var(--amber-bright); }
  .prose-warm :global(pre code) { background:none; padding:0; color:inherit; }
  .prose-warm :global(a) { color:var(--amber); }
  .prose-warm :global(ul), .prose-warm :global(ol) { margin:0 0 10px; padding-left:22px; }
  .prose-warm :global(h1), .prose-warm :global(h2), .prose-warm :global(h3) { font-family:var(--serif); color:var(--text); margin:14px 0 8px; }
  .mini { position:fixed; right:8px; top:118px; bottom:20px; width:8px; display:flex; flex-direction:column; gap:3px; align-items:center; z-index:20; }
  /* On narrow screens the thread rail/minimap would overlay the transcript — hide them. */
  @media (max-width: 900px) { .seg-nav, .mini { display:none; } }
  .mini .m { width:5px; height:8px; border-radius:3px; background:var(--border); display:block; }
  .mini .m.u { background:var(--amber); width:8px; }
  .mini .m.c { background:var(--c-orange); width:8px; }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById("name-threads");
    if (!btn) return;
    btn.addEventListener("click", async function () {
      btn.disabled = true; btn.textContent = "✨ Naming…";
      try {
        var res = await fetch("/api/label", {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ sessionId: btn.dataset.session }),
        });
        if (res.ok) location.reload();
        else { btn.disabled = false; btn.textContent = "✨ Name"; }
      } catch (e) { btn.disabled = false; btn.textContent = "✨ Name"; }
    });
  })();
</script>
<script is:inline define:vars={{ resumeCmd }}>
  const btn = document.getElementById("resume-btn");
  const dlg = document.getElementById("resume-dialog");
  if (btn && dlg) {
    btn.addEventListener("click", () => dlg.showModal());
    document.getElementById("resume-close")?.addEventListener("click", () => dlg.close());
    const copyBtn = document.getElementById("resume-copy");
    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(resumeCmd);
        const prev = copyBtn.textContent;
        copyBtn.textContent = "Copied ✓";
        setTimeout(() => { copyBtn.textContent = prev; }, 1500);
      } catch {
        // Clipboard blocked (e.g. non-secure context): select the command so the user can ⌘C.
        const pre = document.querySelector(".resume-pre");
        if (pre) {
          const range = document.createRange();
          range.selectNodeContents(pre);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      }
    });
  }
</script>
<script is:inline>
  // The conversation opens at its END (latest turn) — scroll up to see earlier history, like a
  // chat. A search deep-link (/?session=<id>#m<lineNo>) overrides this to the matched turn.
  (function () {
    const scroller = document.querySelector(".shell-reader");
    const hash = location.hash;
    const target = /^#m\d+$/.test(hash) ? document.getElementById(hash.slice(1)) : null;
    const toBottom = () => { if (scroller) scroller.scrollTop = scroller.scrollHeight; };
    requestAnimationFrame(() => {
      if (target) {
        target.scrollIntoView({ block: "center" });
        target.classList.add("deep-hit");
        setTimeout(() => target.classList.remove("deep-hit"), 2400);
      } else {
        toBottom();
        // Re-pin after late layout shifts (web-font swap, etc.).
        setTimeout(toBottom, 60);
      }
    });
  })();
</script>
